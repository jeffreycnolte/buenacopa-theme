      "default": "Ver planes →"
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust Badge 1",
      "default": "Envío gratis"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust Badge 2",
      "default": "Garantía 30 días"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Trust Badge 3",
      "default": "Sin riesgo"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    }
