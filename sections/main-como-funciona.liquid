{% comment %}
  Section: Como Funciona (Science / How It Works)
  Standalone page section for the Buenacopa "Como Funciona" page.
  Includes: Hero, Hangover causes, Ingredients, Usage steps, FAQ, CTA.
{% endcomment %}

{%- liquid
  assign hero_heading     = section.settings.hero_heading
  assign hero_subheading  = section.settings.hero_subheading
  assign hero_text        = section.settings.hero_text
  assign causes_heading   = section.settings.causes_heading
  assign causes_subheading = section.settings.causes_subheading
  assign causes_text      = section.settings.causes_text
  assign ingredients_heading    = section.settings.ingredients_heading
  assign ingredients_subheading = section.settings.ingredients_subheading
  assign ingredients_text       = section.settings.ingredients_text
  assign usage_heading    = section.settings.usage_heading
  assign usage_subheading = section.settings.usage_subheading
  assign usage_note       = section.settings.usage_note
  assign faq_heading      = section.settings.faq_heading
  assign cta_heading      = section.settings.cta_heading
  assign cta_text         = section.settings.cta_text
  assign cta_button_label = section.settings.cta_button_label
  assign cta_button_link  = section.settings.cta_button_link
-%}

<!-- ========== 1. HERO ========== -->
<section class="py-16 md:py-24 lg:py-32 bg-background overflow-hidden">
  <div class="container-custom">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-accent font-bold text-sm md:text-base tracking-widest uppercase mb-6">
        {{ hero_subheading }}
      </p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-display font-black text-foreground leading-[0.95] mb-8">
        {{ hero_heading }}
      </h1>
      <p class="text-foreground/70 text-lg md:text-xl lg:text-2xl leading-relaxed font-sans max-w-2xl mx-auto">
        {{ hero_text }}
      </p>
    </div>
  </div>
</section>

<!-- ========== 2. WHAT CAUSES A HANGOVER ========== -->
<section class="section-padding bg-secondary overflow-hidden">
  <div class="container-custom">
    <div class="text-center mb-10 md:mb-14 max-w-3xl mx-auto">
      <p class="text-accent font-bold text-sm md:text-base tracking-widest uppercase mb-4">
        {{ causes_subheading }}
      </p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-black text-foreground mb-4">
        {{ causes_heading }}
      </h2>
      <p class="text-foreground/70 text-base md:text-lg leading-relaxed font-sans">
        {{ causes_text }}
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 md:gap-8 max-w-5xl mx-auto">
      {%- for block in section.blocks -%}
        {%- if block.type == 'cause_card' -%}
          <div class="bg-background/80 backdrop-blur-md border border-white/10 rounded-2xl p-8 flex flex-col gap-5" {{ block.shopify_attributes }}>
            <div class="w-14 h-14 rounded-xl bg-accent/10 flex items-center justify-center text-accent">
              {%- case block.settings.icon -%}
                {%- when 'skull' -%}
                  <!-- Skull / Toxin icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="12" r="1"/><circle cx="15" cy="12" r="1"/><path d="M8 20v2h8v-2"/><path d="m12.5 17-.5-1-.5 1h1z"/><path d="M17 14.5c1.2-1.4 2-3.3 2-5.5 0-3.9-3.1-7-7-7S5 5.1 5 9c0 2.2.8 4.1 2 5.5"/><path d="M7 14.5V17a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-2.5"/></svg>
                {%- when 'brain' -%}
                  <!-- Brain icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/></svg>
                {%- when 'flame' -%}
                  <!-- Flame / Inflammation icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
                {%- else -%}
                  <!-- Default shield icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
              {%- endcase -%}
            </div>
            <h3 class="text-xl md:text-2xl font-display font-black text-accent">
              {{ block.settings.title }}
            </h3>
            <div class="text-foreground/80 leading-relaxed font-sans text-sm md:text-base">
              {{ block.settings.description }}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<!-- ========== 3. INGREDIENTS ========== -->
<section class="section-padding bg-background overflow-hidden">
  <div class="container-custom">
    <div class="text-center mb-12 md:mb-16 max-w-3xl mx-auto">
      <p class="text-accent font-bold text-sm md:text-base tracking-widest uppercase mb-4">
        {{ ingredients_subheading }}
      </p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-black text-foreground mb-4">
        {{ ingredients_heading }}
      </h2>
      <p class="text-foreground/70 text-base md:text-lg leading-relaxed font-sans">
        {{ ingredients_text }}
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 md:gap-8 max-w-4xl mx-auto">
      {%- for block in section.blocks -%}
        {%- if block.type == 'ingredient_card' -%}
          <div class="bg-background/80 backdrop-blur-md border border-white/10 rounded-2xl p-8 md:p-10 flex flex-col gap-5" {{ block.shopify_attributes }}>
            <div class="w-14 h-14 rounded-xl bg-accent/10 flex items-center justify-center text-accent">
              {%- case block.settings.icon -%}
                {%- when 'dhm' -%}
                  <!-- Molecule / DHM icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2"/><circle cx="5" cy="8" r="2"/><circle cx="19" cy="8" r="2"/><circle cx="5" cy="16" r="2"/><circle cx="19" cy="16" r="2"/><line x1="6.7" y1="9.5" x2="10.3" y2="11"/><line x1="13.7" y1="11" x2="17.3" y2="9.5"/><line x1="6.7" y1="14.5" x2="10.3" y2="13"/><line x1="13.7" y1="13" x2="17.3" y2="14.5"/></svg>
                {%- when 'shield' -%}
                  <!-- Shield / L-Cisteina icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
                {%- when 'vitamin' -%}
                  <!-- Sun / Vitamin C icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
                {%- when 'curcuma' -%}
                  <!-- Leaf / Curcuma icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 2c1 2 2 4.5 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
                {%- else -%}
                  <!-- Default pill icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m10.5 20.5 10-10a4.95 4.95 0 1 0-7-7l-10 10a4.95 4.95 0 1 0 7 7Z"/><path d="m8.5 8.5 7 7"/></svg>
              {%- endcase -%}
            </div>
            <div>
              <h3 class="text-2xl md:text-3xl font-display font-black text-accent">
                {{ block.settings.title }}
              </h3>
              {%- if block.settings.subtitle != blank -%}
                <p class="text-muted-foreground text-sm font-medium mt-1">{{ block.settings.subtitle }}</p>
              {%- endif -%}
            </div>
            <div class="text-foreground/85 leading-relaxed font-sans text-sm md:text-base ingredient-description">
              {{ block.settings.description }}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<!-- ========== 4. USAGE INSTRUCTIONS ========== -->
<section class="section-padding bg-background overflow-hidden">
  <div class="container-custom">
    <div class="text-center mb-6 md:mb-8 max-w-3xl mx-auto">
      <p class="text-accent font-bold text-sm md:text-base tracking-widest uppercase mb-4">
        {{ usage_subheading }}
      </p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-black text-foreground mb-4">
        {{ usage_heading }}
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 max-w-5xl mx-auto">
      {%- assign step_number = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'usage_step' -%}
          {%- assign step_number = step_number | plus: 1 -%}
          <div class="text-center flex flex-col items-center gap-4" {{ block.shopify_attributes }}>
            <!-- Step number circle -->
            <div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-accent/10 border-2 border-accent flex items-center justify-center">
              <span class="text-2xl md:text-3xl font-display font-black text-accent">{{ step_number }}</span>
            </div>
            <!-- Step icon -->
            <div class="w-12 h-12 flex items-center justify-center text-foreground/60">
              {%- case block.settings.icon -%}
                {%- when 'glass' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 22h8"/><path d="M12 11v11"/><path d="m19 3-7 8-7-8Z"/></svg>
                {%- when 'capsule' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m10.5 20.5 10-10a4.95 4.95 0 1 0-7-7l-10 10a4.95 4.95 0 1 0 7 7Z"/><path d="m8.5 8.5 7 7"/></svg>
                {%- when 'moon' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
                {%- when 'sun' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
                {%- else -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {%- endcase -%}
            </div>
            <h3 class="text-lg md:text-xl font-display font-bold text-foreground leading-snug">
              {{ block.settings.title }}
            </h3>
            {%- if block.settings.description != blank -%}
              <p class="text-foreground/60 text-sm leading-relaxed font-sans mt-2">
                {{ block.settings.description }}
              </p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if usage_note != blank -%}
      <p class="text-foreground/60 text-sm text-center mt-10 max-w-2xl mx-auto italic font-sans">
        {{ usage_note }}
      </p>
    {%- endif -%}
  </div>
</section>

<!-- ========== 5. FAQ ========== -->
<section id="faq-ciencia" class="section-padding bg-background overflow-hidden">
  <div class="container-custom">
    <div class="text-center mb-12 md:mb-16">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-black text-foreground">
        {{ faq_heading }}
      </h2>
    </div>

    <div class="max-w-3xl mx-auto space-y-3">
      {%- assign faq_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq_item' -%}
          {%- assign faq_index = faq_index | plus: 1 -%}
          {%- assign faq_id = 'cf-faq-answer-' | append: faq_index -%}
          <div class="border border-border/30 rounded-2xl overflow-hidden bg-background/30 cf-faq-item" {{ block.shopify_attributes }}>
            <button
              onclick="toggleCfFaq(this)"
              aria-expanded="false"
              aria-controls="{{ faq_id }}"
              class="w-full flex items-center justify-between p-5 md:p-6 text-left hover:bg-white/[0.03] transition-colors"
            >
              <span class="text-foreground font-bold pr-4 font-sans">{{ block.settings.question }}</span>
              <span class="text-accent flex-shrink-0 transition-transform duration-300 cf-faq-chevron" aria-hidden="true">
                {% render 'icon-chevron-down', size: 20 %}
              </span>
            </button>
            <div class="cf-faq-content" id="{{ faq_id }}" role="region">
              <div>
                <div class="px-5 md:px-6 pb-5 md:pb-6">
                  <p class="text-foreground/80 leading-relaxed font-sans">{{ block.settings.answer }}</p>
                </div>
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<!-- ========== 6. CTA ========== -->
<section class="section-padding bg-accent overflow-hidden">
  <div class="container-custom">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-black text-background mb-4">
        {{ cta_heading }}
      </h2>
      <p class="text-background/80 text-lg md:text-xl leading-relaxed font-sans mb-8">
        {{ cta_text }}
      </p>
      <a
        href="{{ cta_button_link | default: '/#comprar' }}"
        class="inline-flex items-center justify-center px-8 py-4 bg-background text-foreground font-display font-bold text-lg rounded-full hover:bg-background/90 transition-colors"
      >
        {{ cta_button_label }}
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<!-- ========== STYLES ========== -->
<style>
  .cf-faq-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }
  .cf-faq-content > div {
    overflow: hidden;
  }
  .cf-faq-item.is-open .cf-faq-content {
    grid-template-rows: 1fr;
  }
  .cf-faq-item.is-open .cf-faq-chevron {
    transform: rotate(180deg);
  }
  .ingredient-description ul {
    list-style: disc;
    padding-left: 1.25rem;
    margin-top: 0.5rem;
  }
  .ingredient-description li {
    margin-bottom: 0.25rem;
  }
</style>

<!-- ========== SCRIPTS ========== -->
<script>
  function toggleCfFaq(btn) {
    var item = btn.closest('.cf-faq-item');
    var isOpen = item.classList.contains('is-open');
    /* Close all siblings */
    var siblings = item.parentElement.querySelectorAll('.cf-faq-item');
    for (var i = 0; i < siblings.length; i++) {
      siblings[i].classList.remove('is-open');
      siblings[i].querySelector('button').setAttribute('aria-expanded', 'false');
    }
    /* Toggle current */
    if (!isOpen) {
      item.classList.add('is-open');
      btn.setAttribute('aria-expanded', 'true');
    }
  }
</script>

