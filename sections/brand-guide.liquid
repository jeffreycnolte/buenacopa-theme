            <div class="bg-swatch-name">Dark Navy</div>
            <div class="bg-swatch-hex">#001D45</div>
            <div class="bg-swatch-meta">Primary backgrounds, header, footer</div>
            <span class="bg-contrast bg-contrast-pass">16.6:1 vs white ✓ AAA</span>
          </div>
        </div>

        <div class="bg-swatch">
          <div class="bg-swatch-color" style="background: #0056D0;">
            <span style="color: #fff; font-size: 11px; font-weight: 600;">Aa</span>
          </div>
          <div class="bg-swatch-info">
            <div class="bg-swatch-name">Blue</div>
            <div class="bg-swatch-hex">#0056D0</div>
            <div class="bg-swatch-meta">Brand, cards, secondary backgrounds</div>
            <span class="bg-contrast bg-contrast-pass">6.5:1 vs white ✓ AA</span>
          </div>
        </div>

        <div class="bg-swatch">
          <div class="bg-swatch-color" style="background: #B8D4F0;">
            <span style="color: #001D45; font-size: 11px; font-weight: 600;">Aa</span>
          </div>
          <div class="bg-swatch-info">
            <div class="bg-swatch-name">Light Blue</div>
            <div class="bg-swatch-hex">#B8D4F0</div>
            <div class="bg-swatch-meta">Decorative, soft backgrounds</div>
            <span class="bg-contrast bg-contrast-warn">Do not use for text</span>
          </div>
        </div>

        <div class="bg-swatch">
          <div class="bg-swatch-color" style="background: #ECEEE8;">
            <span style="color: #001D45; font-size: 11px; font-weight: 600;">Aa</span>
          </div>
          <div class="bg-swatch-info">
            <div class="bg-swatch-name">Off-White</div>
            <div class="bg-swatch-hex">#ECEEE8</div>
