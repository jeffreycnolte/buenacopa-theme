            has_subscription: bg_has_sub,
            sub_variant_id: bg_sub_variant.id,
            sub_plan_id: bg_sub_plan.id,
            sub_price_raw: bg_sub_price,
            sub_servings: bg_sub_servings,
            sub_price_whole: bg_sub_price_whole,
            sub_price_cents: bg_sub_price_cents,
            sub_compare_whole: bg_sub_compare_whole,
            sub_per_whole: bg_sub_per_whole,
            variants: bg_product.variants,
            trust_ssl: bg_t_ssl,
            trust_shipping: bg_t_shipping,
            trust_guarantee: bg_t_guarantee
          %}
        {%- else -%}
          <p style="font-size: 13px; color: #9ca3af; text-align: center; padding: 24px 0;">No product available to render the live buybox demo. Assign one in the theme editor → Brand Guide section → Buy-box product.</p>
        {%- endif -%}
