<footer class="bg-secondary/50 border-t border-border overflow-hidden">
  <div class="container-custom py-12 md:py-16">
    <div class="grid md:grid-cols-4 gap-8">

      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="block mb-3">
          {% if section.settings.logo %}
            <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="h-7 w-auto" width="100" height="28">
          {% else %}
            <img src="{{ 'logo-offwhite.png' | asset_url }}" alt="{{ shop.name }}" class="h-7 w-auto" width="100" height="28">
          {% endif %}
        </a>
        <p class="text-muted-foreground text-sm leading-relaxed">
          {{ section.settings.tagline | default: 'Bienestar post-fiesta. Celebra hoy, conquista mañana.' }}
        </p>

        <!-- Social icons pulled from Shopify Theme Settings > Social media -->
        <ul class="flex gap-3 mt-4 list-unstyled" role="list">
          {% render 'social-icons' %}
        </ul>
      </div>

      <!-- Link Groups -->
      {% for block in section.blocks %}
        {% if block.type == 'link_group' %}
          <div {{ block.shopify_attributes }}>
            <h3 class="font-bold text-foreground text-sm mb-4">{{ block.settings.heading | escape }}</h3>
            {% if block.settings.menu != blank %}
              <ul class="space-y-2 text-sm">
                {% for link in block.settings.menu.links %}
                  <li>
                    <a href="{{ link.url }}" class="text-muted-foreground hover:text-foreground transition-colors{% if link.active %} text-foreground{% endif %}">
                      {{ link.title }}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-border mt-10 pt-6 flex flex-col md:flex-row items-center justify-between gap-4">

      <div class="flex flex-wrap justify-center md:justify-start gap-x-4 gap-y-1">
        <small class="text-muted-foreground text-xs">
          &copy; {{ 'now' | date: '%Y' }}, <a href="{{ routes.root_url }}" class="hover:text-foreground transition-colors">{{ shop.name }}</a>. {{ section.settings.copyright_text }}
        </small>
        {% if section.settings.show_policy %}
          {% for policy in shop.policies %}
            {% if policy != blank %}
              <small class="text-muted-foreground text-xs">
                <a href="{{ policy.url }}" class="hover:text-foreground transition-colors">{{ policy.title }}</a>
              </small>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>

      <!-- Payment icons pulled from Shopify Payments settings -->
      {% if section.settings.payment_enable %}
        <div class="footer__payment">
          <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
          <ul class="list list-payment flex flex-wrap gap-1" role="list">
            {% for type in shop.enabled_payment_types %}
              <li>{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}</li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}

    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "shopify-section-footer",
  "max_blocks": 4,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Bienestar post-fiesta. Celebra hoy, conquista mañana."
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": true,
      "label": "Show payment icons"
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "default": false,
      "label": "Show policy links"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "default": "Todos los derechos reservados.",
      "label": "Copyright text"
    }
  ],
  "blocks": [
    {
      "type": "link_group",
      "name": "Link Group",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_group", "settings": { "heading": "Producto" } },
        { "type": "link_group", "settings": { "heading": "Soporte" } },
        { "type": "link_group", "settings": { "heading": "Legal" } }
      ]
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}