<footer class="bg-secondary/50 border-t border-border overflow-hidden">
  <div class="container-custom py-12 md:py-16">
    <div class="grid md:grid-cols-4 gap-8">

      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="block mb-3">
          {% if section.settings.logo %}
            <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="h-7 w-auto" width="100" height="28">
          {% else %}
            <img src="{{ 'logo-offwhite.png' | asset_url }}" alt="{{ shop.name }}" class="h-7 w-auto" width="100" height="28">
          {% endif %}
        </a>
        <p class="text-muted-foreground text-sm leading-relaxed">
          {% render 'brand/tagline', override: section.settings.tagline %}
        </p>

        <div class="flex gap-3 mt-4">
          {% if settings.social_instagram_link != blank %}
            <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-11 h-11 rounded-full bg-white/5 border border-border flex items-center justify-center hover:border-accent transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {% endif %}
          {% if settings.social_facebook_link != blank %}
            <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-11 h-11 rounded-full bg-white/5 border border-border flex items-center justify-center hover:border-accent transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          {% endif %}
          {% if settings.social_tiktok_link != blank %}
            <a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="w-11 h-11 rounded-full bg-white/5 border border-border flex items-center justify-center hover:border-accent transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      <!-- Link Groups -->
      {% for block in section.blocks %}
        {% if block.type == 'link_group' %}
          <div {{ block.shopify_attributes }}>
            <h3 class="font-bold text-foreground text-sm mb-4">{{ block.settings.heading | escape }}</h3>
            {% if block.settings.menu != blank %}
              <ul class="space-y-1 text-sm">
                {% for link in block.settings.menu.links %}
                  <li>
                    <a href="{{ link.url }}" class="text-muted-foreground hover:text-foreground transition-colors py-1.5 inline-block{% if link.active %} text-foreground{% endif %}">
                      {{ link.title }}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-border mt-10 pt-6 flex flex-col md:flex-row items-center justify-between gap-4">

      <div class="flex flex-wrap justify-center md:justify-start gap-x-4 gap-y-1">
        <small class="text-muted-foreground text-xs">
          &copy; {{ 'now' | date: '%Y' }}, <a href="{{ routes.root_url }}" class="hover:text-foreground transition-colors">{{ shop.name }}</a>. {{ section.settings.copyright_text }}
        </small>
        {% if section.settings.show_policy %}
          {% for policy in shop.policies %}
            {% if policy != blank %}
              <small class="text-muted-foreground text-xs">
                <a href="{{ policy.url }}" class="hover:text-foreground transition-colors">{{ policy.title }}</a>
              </small>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>

      {% if section.settings.payment_enable %}
        <div class="footer__payment text-right">
          <p class="text-muted-foreground text-xs font-bold uppercase tracking-wider mb-2">Métodos de pago</p>
          <ul class="list list-payment flex flex-wrap justify-end gap-1.5" role="list">
            {% for type in shop.enabled_payment_types %}
              <li class="bg-white/10 rounded px-1 py-0.5">{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}</li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}

    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "shopify-section-footer",
  "max_blocks": 4,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Buenacopa, bienestar post-fiesta."
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": true,
      "label": "Show payment icons"
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "default": false,
      "label": "Show policy links"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "default": "Todos los derechos reservados.",
      "label": "Copyright text"
    }
  ],
  "blocks": [
    {
      "type": "link_group",
      "name": "Link Group",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_group", "settings": { "heading": "Producto" } },
        { "type": "link_group", "settings": { "heading": "Soporte" } },
        { "type": "link_group", "settings": { "heading": "Legal" } }
      ]
    }
  ]
}
{% endschema %}