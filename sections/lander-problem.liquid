{%- comment -%}
  Lander Problem — Make them feel seen in one line.
  Lifestyle image + bold copy. One screen on mobile.
{%- endcomment -%}

<section class="overflow-hidden" style="padding: 3rem 0; background-color: #FAF7F2;">
  <div class="container-custom text-center">

    {%- comment -%}Lifestyle image — customizer image or fallback to step-01-celebra asset{%- endcomment -%}
    <div class="mx-auto rounded-2xl overflow-hidden" style="max-width: 480px; margin-bottom: 24px;">
      {% if section.settings.image %}
        <img
          src="{{ section.settings.image | image_url: width: 960 }}"
          srcset="{{ section.settings.image | image_url: width: 480 }} 480w, {{ section.settings.image | image_url: width: 960 }} 960w"
          sizes="(max-width: 768px) 100vw, 480px"
          alt="{{ section.settings.image_alt | default: 'Celebrating with friends' }}"
          class="w-full h-auto"
          style="aspect-ratio: 4/3; object-fit: cover;"
          width="480" height="360"
          loading="lazy"
          decoding="async"
        >
      {% else %}
        <img
          src="{{ 'lander-problem-lifestyle.jpg' | asset_url }}"
          alt="Living in the moment"
          class="w-full h-auto"
          style="aspect-ratio: 4/3; object-fit: cover;"
          width="480" height="360"
          loading="lazy"
          decoding="async"
        >
      {% endif %}
    </div>

    {%- comment -%}Bold one-liner{%- endcomment -%}
    <h2 class="font-display font-black" style="font-size: clamp(1.5rem, 5vw, 2.5rem); line-height: 1.1; max-width: 560px; margin: 0 auto; color: #001D45;">
      {{ section.settings.heading | default: 'Celebras bien. Sufres solo/sola el domingo.' }}
    </h2>

    {% if section.settings.subtext != blank %}
      <p class="font-medium" style="font-size: 15px; margin-top: 10px; color: rgba(7,29,64,0.5);">
        {{ section.settings.subtext }}
      </p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Lander Problem",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Celebras bien. Sufres solo/sola el domingo."
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext (optional)",
      "default": "No tiene que ser así."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image Alt Text",
      "default": "Friends celebrating"
    }
  ],
  "presets": [
    {
      "name": "Lander Problem"
    }
  ]
}
{% endschema %}
