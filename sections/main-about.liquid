{% comment %}
  Sobre Nosotros (About Us) — Buenacopa theme section
  Renders: Hero, Manifesto, Story/Mission/Vision, Values, Commitment
  Designed to look great with or without images.
{% endcomment %}

{%- liquid
  assign hero_heading = section.settings.hero_heading
  assign manifesto_heading = section.settings.manifesto_heading
  assign manifesto_text = section.settings.manifesto_text
  assign history_heading = section.settings.history_heading
  assign history_text = section.settings.history_text
  assign mission_heading = section.settings.mission_heading
  assign mission_text = section.settings.mission_text
  assign vision_heading = section.settings.vision_heading
  assign vision_text = section.settings.vision_text
  assign values_subheading = section.settings.values_subheading
  assign values_heading = section.settings.values_heading
  assign values_description = section.settings.values_description
  assign commitment_heading = section.settings.commitment_heading
  assign commitment_text = section.settings.commitment_text
-%}

<!-- ═══════ 1. HERO ═══════ -->
<section class="bg-accent relative overflow-hidden">
  {%- if section.settings.hero_image -%}
    <div class="absolute inset-0 z-0">
      <img
        src="{{ section.settings.hero_image | image_url: width: 1920 }}"
        srcset="{{ section.settings.hero_image | image_url: width: 768 }} 768w, {{ section.settings.hero_image | image_url: width: 1920 }} 1920w"
        sizes="100vw"
        alt=""
        class="w-full h-full object-cover opacity-20"
        loading="eager"
        width="1920" height="800" decoding="async"
      >
    </div>
  {%- endif -%}
  <div class="container-custom relative z-10 text-center py-16 md:py-20 lg:py-24">
    <h1 class="text-4xl sm:text-5xl md:text-6xl font-display font-black text-white leading-tight">
      {{ hero_heading }}
    </h1>
    {%- if section.settings.hero_subtitle != blank -%}
      <p class="mt-4 md:mt-6 text-lg md:text-xl text-white/80 font-sans max-w-2xl mx-auto leading-relaxed">
        {{ section.settings.hero_subtitle }}
      </p>
    {%- endif -%}
  </div>
</section>

<!-- ═══════ 2. MANIFESTO ═══════ -->
<section class="section-padding bg-background">
  <div class="container-custom max-w-4xl">
    <div class="text-center mb-8 md:mb-10">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-black text-foreground">
        {{ manifesto_heading }}
      </h2>
    </div>

    {%- if section.settings.manifesto_image -%}
      <div class="mb-10 md:mb-12">
        <img
          src="{{ section.settings.manifesto_image | image_url: width: 960 }}"
          srcset="{{ section.settings.manifesto_image | image_url: width: 480 }} 480w, {{ section.settings.manifesto_image | image_url: width: 960 }} 960w"
          sizes="(max-width: 768px) 100vw, 960px"
          alt="{{ manifesto_heading }}"
          class="w-full rounded-2xl object-cover max-h-[400px]"
          loading="lazy" width="960" height="400" decoding="async"
        >
      </div>
    {%- endif -%}

    <div class="text-foreground/85 font-sans text-lg md:text-xl leading-relaxed space-y-6 text-center">
      {{ manifesto_text }}
    </div>

    <div class="flex items-center justify-center gap-4 mt-10 md:mt-12">
      <span class="h-px w-16 bg-accent/40"></span>
      <span class="w-2.5 h-2.5 rounded-full bg-accent"></span>
      <span class="h-px w-16 bg-accent/40"></span>
    </div>
  </div>
</section>

<!-- ═══════ 3. STORY / MISSION / VISION ═══════ -->
<section class="section-padding bg-background/95 border-t border-b border-foreground/5">
  <div class="container-custom">
    {%- if section.settings.story_image -%}
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div class="space-y-10 md:space-y-12">
    {%- else -%}
      <div class="max-w-4xl mx-auto">
        <div class="grid md:grid-cols-3 gap-8 md:gap-10">
    {%- endif -%}

          <!-- Historia -->
          <div class="{% unless section.settings.story_image %}text-center{% endunless %}">
            <div class="flex items-center gap-3 mb-4 {% unless section.settings.story_image %}justify-center{% endunless %}">
              <span class="w-10 h-10 rounded-lg bg-accent/15 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
              </span>
              <h3 class="text-xl md:text-2xl font-display font-black text-foreground">
                {{ history_heading }}
              </h3>
            </div>
            <p class="text-foreground/70 font-sans leading-relaxed">{{ history_text }}</p>
          </div>

          <!-- Mision -->
          <div class="{% unless section.settings.story_image %}text-center{% endunless %}">
            <div class="flex items-center gap-3 mb-4 {% unless section.settings.story_image %}justify-center{% endunless %}">
              <span class="w-10 h-10 rounded-lg bg-accent/15 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </span>
              <h3 class="text-xl md:text-2xl font-display font-black text-foreground">
                {{ mission_heading }}
              </h3>
            </div>
            <p class="text-foreground/70 font-sans leading-relaxed">{{ mission_text }}</p>
          </div>

          <!-- Vision -->
          <div class="{% unless section.settings.story_image %}text-center{% endunless %}">
            <div class="flex items-center gap-3 mb-4 {% unless section.settings.story_image %}justify-center{% endunless %}">
              <span class="w-10 h-10 rounded-lg bg-accent/15 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              </span>
              <h3 class="text-xl md:text-2xl font-display font-black text-foreground">
                {{ vision_heading }}
              </h3>
            </div>
            <p class="text-foreground/70 font-sans leading-relaxed">{{ vision_text }}</p>
          </div>

        </div>

        {%- if section.settings.story_image -%}
          <div>
            <img
              src="{{ section.settings.story_image | image_url: width: 800 }}"
              srcset="{{ section.settings.story_image | image_url: width: 480 }} 480w, {{ section.settings.story_image | image_url: width: 800 }} 800w"
              sizes="(max-width: 1024px) 100vw, 50vw"
              alt="{{ history_heading }}"
              class="w-full rounded-2xl object-cover"
              loading="lazy" width="800" height="900" decoding="async"
            >
          </div>
        {%- endif -%}
      </div>
  </div>
</section>

<!-- ═══════ 4. VALUES ═══════ -->
<section class="section-padding bg-primary/80">
  <div class="container-custom">
    <div class="text-center mb-12 md:mb-16 max-w-3xl mx-auto">
      {%- if values_subheading != blank -%}
        <p class="text-accent font-sans font-bold text-sm md:text-base uppercase tracking-wider mb-3">
          {{ values_subheading }}
        </p>
      {%- endif -%}
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-black text-foreground">
        {{ values_heading }}
      </h2>
      {%- if values_description != blank -%}
        <p class="mt-4 text-foreground/70 font-sans text-base md:text-lg leading-relaxed max-w-2xl mx-auto">
          {{ values_description }}
        </p>
      {%- endif -%}
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {% for block in section.blocks %}
        {% if block.type == 'value' %}
          <div class="bg-background/10 backdrop-blur-sm border border-foreground/10 rounded-2xl p-6 md:p-8 text-center transition-all duration-300 hover:bg-background/20 hover:border-accent/30" {{ block.shopify_attributes }}>
            <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-accent/15 flex items-center justify-center">
              {% case block.settings.icon %}
                {% when 'balance' %}
                  <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m-8-9H3m18 0h-1m-2.636-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707"/><circle cx="12" cy="12" r="4"/><path stroke-linecap="round" d="M9 12h6"/></svg>
                {% when 'science' %}
                  <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714a2.25 2.25 0 00.659 1.591L19 14.5m-4.75-11.396c.251.023.501.05.75.082M12 6v3m-3.75 6h7.5a2.25 2.25 0 012.25 2.25v.75a2.25 2.25 0 01-2.25 2.25h-7.5A2.25 2.25 0 016 18v-.75A2.25 2.25 0 018.25 15z"/></svg>
                {% when 'responsibility' %}
                  <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
                {% when 'innovation' %}
                  <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/></svg>
                {% when 'wellness' %}
                  <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
                {% when 'accessibility' %}
                  <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
                {% else %}
                  <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
              {% endcase %}
            </div>
            <h3 class="text-lg md:text-xl font-display font-black text-foreground mb-2">
              {{ block.settings.title }}
            </h3>
            <p class="text-foreground/65 font-sans leading-relaxed text-sm">
              {{ block.settings.description }}
            </p>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<!-- ═══════ 5. COMMITMENT ═══════ -->
<section class="section-padding bg-background">
  <div class="container-custom max-w-4xl text-center">
    <div class="flex items-center justify-center gap-4 mb-8">
      <span class="h-px w-10 bg-accent"></span>
      <span class="w-2 h-2 rounded-full bg-accent"></span>
      <span class="h-px w-10 bg-accent"></span>
    </div>
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-black text-foreground mb-8 md:mb-10">
      {{ commitment_heading }}
    </h2>
    <div class="text-foreground/80 font-sans text-lg leading-relaxed space-y-5">
      {{ commitment_text }}
    </div>
    {%- if section.settings.commitment_cta_text != blank -%}
      <div class="mt-10">
        <a href="{{ section.settings.commitment_cta_url | default: '/' | append: '#comprar' }}" class="btn-cta inline-flex items-center gap-2 group text-base">
          {{ section.settings.commitment_cta_text }}
          <span class="group-hover:translate-x-1 transition-transform inline-flex">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </span>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Sobre Nosotros",
  "tag": "div",
  "class": "about-page",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Heading",
      "default": "Sobre Nosotros"
    },
    {
      "type": "text",
      "id": "hero_subtitle",
      "label": "Subtitle",
      "default": "La fiesta sigue. La cruda no. Conoce la historia detrás de Buenacopa."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image"
    },
    {
      "type": "header",
      "content": "Manifiesto"
    },
    {
      "type": "text",
      "id": "manifesto_heading",
      "label": "Manifesto Heading",
      "default": "Nuestro Manifiesto"
    },
    {
      "type": "richtext",
      "id": "manifesto_text",
      "label": "Manifesto Text",
      "default": "<p>Hay cosas que no necesitan explicación. Un brindis por lo que fue. Una copa por lo que vendrá. Un \"¡Salud!\" que suena más fuerte cuando se comparte.</p><p>Celebrar está en nuestra naturaleza. Porque la vida no solo se vive, se celebra. Y si celebrar es parte de la vida, cuidarte también debería serlo. No como una restricción, sino como un acto de amor propio. De equilibrio.</p><p>Buenacopa nace de esa idea: De unir el gozo de la celebración con el poder de la ciencia y la conciencia. Buenacopa no es un antídoto. Es una decisión. Una nueva forma de brindar. Con alegría, con conciencia, con equilibrio. Porque lo que empieza con una buena copa… merece terminar con un buen día. Buenacopa. Buenos días.</p>"
    },
    {
      "type": "image_picker",
      "id": "manifesto_image",
      "label": "Manifesto Image (optional)"
    },
    {
      "type": "header",
      "content": "Historia / Misión / Visión"
    },
    {
      "type": "text",
      "id": "history_heading",
      "label": "History Heading",
      "default": "Nuestra Historia"
    },
    {
      "type": "textarea",
      "id": "history_text",
      "label": "History Text",
      "default": "Buenacopa surgió de nuestras propias experiencias con DHM (Dihidromiricetina) y su sorprendente efectividad. Inspirados por los resultados, decidimos crear la primera solución post-fiesta con respaldo científico en México, una que promueve una relación equilibrada con el alcohol y respeta tanto los momentos de alegría como el bienestar del día siguiente."
    },
    {
      "type": "text",
      "id": "mission_heading",
      "label": "Mission Heading",
      "default": "Nuestra Misión"
    },
    {
      "type": "textarea",
      "id": "mission_text",
      "label": "Mission Text",
      "default": "Apoyamos la celebración consciente ofreciendo productos con respaldo científico que ayudan a mantener el equilibrio entre el disfrute y el bienestar personal. Buscamos transformar la relación de los mexicanos con el alcohol, promoviendo el cuidado personal como parte integral de la experiencia de celebración."
    },
    {
      "type": "text",
      "id": "vision_heading",
      "label": "Vision Heading",
      "default": "Nuestra Visión"
    },
    {
      "type": "textarea",
      "id": "vision_text",
      "label": "Vision Text",
      "default": "Convertirnos en la marca más confiable y accesible de México en bienestar post-fiesta, haciendo posible que más personas disfruten plenamente de la vida sin sacrificar el día siguiente."
    },
    {
      "type": "image_picker",
      "id": "story_image",
      "label": "Story Section Image (optional)"
    },
    {
      "type": "header",
      "content": "Valores"
    },
    {
      "type": "text",
      "id": "values_subheading",
      "label": "Values Subheading",
      "default": "Lo que creemos define lo que creamos"
    },
    {
      "type": "text",
      "id": "values_heading",
      "label": "Values Heading",
      "default": "Nuestros Valores"
    },
    {
      "type": "textarea",
      "id": "values_description",
      "label": "Values Description",
      "default": "Cada decisión detrás de BUENACOPA nace de nuestros valores. No hacemos atajos, hacemos lo correcto."
    },
    {
      "type": "header",
      "content": "Compromiso"
    },
    {
      "type": "text",
      "id": "commitment_heading",
      "label": "Commitment Heading",
      "default": "Nuestro Compromiso"
    },
    {
      "type": "richtext",
      "id": "commitment_text",
      "label": "Commitment Text",
      "default": "<p>Creemos que está surgiendo una nueva forma de relacionarnos con la celebración – una que honra su lugar en nuestra cultura pero que también prioriza nuestro bienestar.</p><p>No buscamos cambiar la forma en que socializas, sino complementarla con el cuidado personal. Queremos ser el puente entre disfrutar plenamente tus noches y despertar con energía para aprovechar tus días.</p><p>Porque creemos que los momentos de celebración son valiosos, pero también lo son las mañanas productivas, los entrenamientos energéticos y las mentes despejadas.</p><p>Únete a nosotros en este camino hacia un equilibrio entre la vida social y el bienestar personal. Con Buenacopa, puedes decir sí a ambos.</p>"
    },
    {
      "type": "text",
      "id": "commitment_cta_text",
      "label": "CTA Button Text",
      "default": "Comprar ahora"
    },
    {
      "type": "url",
      "id": "commitment_cta_url",
      "label": "CTA Button URL"
    },
    {
      "type": "image_picker",
      "id": "commitment_image_1",
      "label": "Commitment Image 1 (optional)"
    },
    {
      "type": "image_picker",
      "id": "commitment_image_2",
      "label": "Commitment Image 2 (optional)"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "balance", "label": "Balance (Equilibrio)" },
            { "value": "science", "label": "Science (Ciencia)" },
            { "value": "responsibility", "label": "Shield (Responsabilidad)" },
            { "value": "innovation", "label": "Lightbulb (Innovación)" },
            { "value": "wellness", "label": "Heart (Bienestar)" },
            { "value": "accessibility", "label": "People (Accesibilidad)" }
          ],
          "default": "balance"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Valor"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sobre Nosotros",
      "blocks": [
        { "type": "value", "settings": { "icon": "balance", "title": "Equilibrio", "description": "Creemos que disfrutar y sentirte bien al día siguiente no son cosas opuestas." } },
        { "type": "value", "settings": { "icon": "science", "title": "Ciencia", "description": "Cada ingrediente está respaldado por investigación científica, no por promesas vacías." } },
        { "type": "value", "settings": { "icon": "responsibility", "title": "Responsabilidad", "description": "Promovemos el consumo consciente y responsable en cada momento." } },
        { "type": "value", "settings": { "icon": "innovation", "title": "Innovación", "description": "Buscamos constantemente mejorar nuestra fórmula con los últimos avances científicos." } },
        { "type": "value", "settings": { "icon": "wellness", "title": "Bienestar", "description": "Tu bienestar integral es nuestra prioridad, antes, durante y después de celebrar." } },
        { "type": "value", "settings": { "icon": "accessibility", "title": "Accesibilidad", "description": "Queremos que todos puedan acceder a una solución efectiva y de calidad." } }
      ]
    }
  ]
}
{% endschema %}
