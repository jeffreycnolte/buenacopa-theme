{% comment %}
  Sobre Nosotros — Buenacopa
  Sections: Manifesto, Story/Mission/Vision, Values, Commitment, Brand Moment
{% endcomment %}

<!-- ═══════ 1. MANIFIESTO ═══════ -->
<section class="bg-primary overflow-hidden">
  <div class="container-custom py-16 md:py-24 lg:py-28">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">

      <div class="order-2 lg:order-1 text-foreground">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-black mb-6 md:mb-8 leading-tight">
          {{ section.settings.manifesto_heading }}
        </h2>
        <div class="text-foreground/90 text-base md:text-lg leading-relaxed space-y-5 font-sans">
          {{ section.settings.manifesto_text }}
        </div>
      </div>

      <div class="order-1 lg:order-2">
        {%- if section.settings.manifesto_image -%}
          <img
            src="{{ section.settings.manifesto_image | image_url: width: 1000 }}"
            srcset="{{ section.settings.manifesto_image | image_url: width: 500 }} 500w, {{ section.settings.manifesto_image | image_url: width: 1000 }} 1000w"
            sizes="(max-width: 1024px) 100vw, 50vw"
            alt="{{ section.settings.manifesto_heading }}"
            class="w-full rounded-2xl object-cover"
            style="aspect-ratio: 4/5;"
            loading="eager" width="1000" height="1250" decoding="async"
          >
        {%- else -%}
          <img
            src="{{ 'lander-problem-lifestyle.jpg' | asset_url }}"
            alt="{{ section.settings.manifesto_heading }}"
            class="w-full rounded-2xl object-cover"
            style="aspect-ratio: 4/5;"
            loading="eager" width="1000" height="1250" decoding="async"
          >
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

<!-- ═══════ 2. HISTORIA / MISIÓN / VISIÓN ═══════ -->
<section class="bg-white">
  <div class="container-custom py-16 md:py-24 lg:py-28">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-start">

      <div>
        {%- if section.settings.story_image -%}
          <img
            src="{{ section.settings.story_image | image_url: width: 1000 }}"
            srcset="{{ section.settings.story_image | image_url: width: 500 }} 500w, {{ section.settings.story_image | image_url: width: 1000 }} 1000w"
            sizes="(max-width: 1024px) 100vw, 50vw"
            alt="{{ section.settings.history_heading }}"
            class="w-full rounded-2xl object-cover lg:sticky lg:top-8"
            style="aspect-ratio: 4/5;"
            loading="lazy" width="1000" height="1250" decoding="async"
          >
        {%- else -%}
          <img
            src="{{ 'lander-solution-lifestyle.jpg' | asset_url }}"
            alt="{{ section.settings.history_heading }}"
            class="w-full rounded-2xl object-cover lg:sticky lg:top-8"
            style="aspect-ratio: 4/5;"
            loading="lazy" width="1000" height="1250" decoding="async"
          >
        {%- endif -%}
      </div>

      <div class="space-y-10 md:space-y-12" style="color: #071D40;">
        <div>
          <h3 class="text-2xl md:text-3xl font-display font-black mb-3 leading-tight">
            {{ section.settings.history_heading }}
          </h3>
          <p class="font-sans leading-relaxed text-base md:text-lg" style="color: #071D40cc;">
            {{ section.settings.history_text }}
          </p>
        </div>
        <div>
          <h3 class="text-2xl md:text-3xl font-display font-black mb-3 leading-tight">
            {{ section.settings.mission_heading }}
          </h3>
          <p class="font-sans leading-relaxed text-base md:text-lg" style="color: #071D40cc;">
            {{ section.settings.mission_text }}
          </p>
        </div>
        <div>
          <h3 class="text-2xl md:text-3xl font-display font-black mb-3 leading-tight">
            {{ section.settings.vision_heading }}
          </h3>
          <p class="font-sans leading-relaxed text-base md:text-lg" style="color: #071D40cc;">
            {{ section.settings.vision_text }}
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ═══════ 3. VALORES ═══════ -->
<section class="bg-primary overflow-hidden">
  <div class="container-custom py-16 md:py-24 lg:py-28">
    <div class="text-center max-w-3xl mx-auto mb-12 md:mb-16 text-foreground">
      {%- if section.settings.values_subheading != blank -%}
        <p class="text-foreground/70 font-sans font-bold text-xs uppercase mb-4" style="letter-spacing: 0.2em;">
          {{ section.settings.values_subheading }}
        </p>
      {%- endif -%}
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-black mb-4">
        {{ section.settings.values_heading }}
      </h2>
      {%- if section.settings.values_description != blank -%}
        <p class="text-foreground/80 font-sans text-base md:text-lg leading-relaxed">
          {{ section.settings.values_description }}
        </p>
      {%- endif -%}
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10 md:gap-12 max-w-5xl mx-auto">
      {%- for block in section.blocks -%}
        {%- if block.type == 'value' -%}
          <div class="text-center text-foreground" {{ block.shopify_attributes }}>
            <div class="w-10 h-10 md:w-12 md:h-12 mx-auto mb-5 flex items-center justify-center text-accent">
              {%- case block.settings.icon -%}
                {%- when 'balance' -%}
                  <svg class="w-8 h-8 md:w-10 md:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m-8-9H3m18 0h-1m-2.636-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707"/><circle cx="12" cy="12" r="4"/><path stroke-linecap="round" d="M9 12h6"/></svg>
                {%- when 'science' -%}
                  <svg class="w-8 h-8 md:w-10 md:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714a2.25 2.25 0 00.659 1.591L19 14.5m-4.75-11.396c.251.023.501.05.75.082M12 6v3m-3.75 6h7.5a2.25 2.25 0 012.25 2.25v.75a2.25 2.25 0 01-2.25 2.25h-7.5A2.25 2.25 0 016 18v-.75A2.25 2.25 0 018.25 15z"/></svg>
                {%- when 'responsibility' -%}
                  <svg class="w-8 h-8 md:w-10 md:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
                {%- when 'innovation' -%}
                  <svg class="w-8 h-8 md:w-10 md:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/></svg>
                {%- when 'wellness' -%}
                  <svg class="w-8 h-8 md:w-10 md:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
                {%- when 'accessibility' -%}
                  <svg class="w-8 h-8 md:w-10 md:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
                {%- else -%}
                  <svg class="w-8 h-8 md:w-10 md:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
              {%- endcase -%}
            </div>
            <h3 class="text-lg md:text-xl font-display font-black mb-2">
              {{ block.settings.title }}
            </h3>
            <p class="text-foreground/75 font-sans leading-relaxed text-sm md:text-base">
              {{ block.settings.description }}
            </p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<!-- ═══════ 4. COMPROMISO ═══════ -->
<section class="bg-white overflow-hidden">
  <div class="container-custom py-16 md:py-24 lg:py-28">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">

      <div style="color: #071D40;">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-black mb-6 md:mb-8 leading-tight">
          {{ section.settings.commitment_heading }}
        </h2>
        <div class="font-sans text-base md:text-lg leading-relaxed space-y-5" style="color: #071D40cc;">
          {{ section.settings.commitment_text }}
        </div>
        {%- if section.settings.commitment_cta_text != blank -%}
          <div class="mt-10">
            <a href="{{ section.settings.commitment_cta_url | default: '/#comprar' }}" class="btn-cta inline-flex items-center gap-2 group text-base">
              {{ section.settings.commitment_cta_text }}
              <span class="group-hover:translate-x-1 transition-transform inline-flex">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
              </span>
            </a>
          </div>
        {%- endif -%}
      </div>

      <!-- Image collage -->
      {%- assign c1 = section.settings.commitment_image_1 -%}
      {%- assign c2 = section.settings.commitment_image_2 -%}
      {%- assign c3 = section.settings.commitment_image_3 -%}
      {%- if c1 -%}
        {%- assign c1_src = c1 | image_url: width: 480 -%}
      {%- else -%}
        {%- assign c1_src = 'review-1.png' | asset_url -%}
      {%- endif -%}
      {%- if c2 -%}
        {%- assign c2_src = c2 | image_url: width: 480 -%}
      {%- else -%}
        {%- assign c2_src = 'review-2.png' | asset_url -%}
      {%- endif -%}
      {%- if c3 -%}
        {%- assign c3_src = c3 | image_url: width: 400 -%}
      {%- else -%}
        {%- assign c3_src = 'review-3.png' | asset_url -%}
      {%- endif -%}

      <!-- Mobile: simple 2-col grid -->
      <div class="grid grid-cols-2 gap-4 lg:hidden">
        <img src="{{ c1_src }}" alt="" class="w-full rounded-2xl object-cover shadow-lg" style="aspect-ratio: 4/3;" loading="lazy" width="480" height="360" decoding="async">
        <img src="{{ c2_src }}" alt="" class="w-full rounded-2xl object-cover shadow-lg" style="aspect-ratio: 4/3;" loading="lazy" width="480" height="360" decoding="async">
        <img src="{{ c3_src }}" alt="" class="col-span-2 w-full rounded-2xl object-cover shadow-lg" style="aspect-ratio: 16/7;" loading="lazy" width="800" height="350" decoding="async">
      </div>

      <!-- Desktop: offset collage -->
      <div class="relative hidden lg:block" style="height: 520px;">
        <div class="absolute" style="top: 0; left: 0; width: 52%; z-index: 1; transform: rotate(-3deg);">
          <img src="{{ c1_src }}" alt="" class="w-full rounded-2xl object-cover shadow-xl" style="aspect-ratio: 4/3;" loading="lazy" width="480" height="360" decoding="async">
        </div>
        <div class="absolute" style="top: 30px; right: 0; width: 52%; z-index: 2; transform: rotate(2deg);">
          <img src="{{ c2_src }}" alt="" class="w-full rounded-2xl object-cover shadow-xl" style="aspect-ratio: 3/4;" loading="lazy" width="480" height="640" decoding="async">
        </div>
        <div class="absolute" style="bottom: 0; left: 8%; width: 42%; z-index: 3; transform: rotate(1deg);">
          <img src="{{ c3_src }}" alt="" class="w-full rounded-2xl object-cover shadow-xl" style="aspect-ratio: 3/4;" loading="lazy" width="400" height="533" decoding="async">
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ═══════ 5. BRAND MOMENT: BUENACOPA / BUENOS DÍAS ═══════ -->
<section class="bg-primary relative overflow-hidden">
  <div class="container-custom py-12 md:py-16 lg:py-20">
    <div class="relative">
      <!-- Accessible heading (visually hidden) -->
      <h2 class="sr-only">{{ section.settings.banner_line_1 }} {{ section.settings.banner_line_2 }}</h2>
      <!-- Decorative display text -->
      <div class="text-center font-display font-black text-foreground leading-none tracking-tight select-none" aria-hidden="true">
        <div style="font-size: clamp(4rem, 18vw, 14rem); line-height: 0.88;">
          {{ section.settings.banner_line_1 }}
        </div>
        <div style="font-size: clamp(4rem, 18vw, 14rem); line-height: 0.88;">
          {{ section.settings.banner_line_2 }}
        </div>
      </div>
      <!-- Person image layered on top -->
      {%- if section.settings.banner_image -%}
        <div class="absolute inset-0 flex items-end justify-center pointer-events-none" style="padding-bottom: 0;">
          <img
            src="{{ section.settings.banner_image | image_url: width: 800 }}"
            srcset="{{ section.settings.banner_image | image_url: width: 400 }} 400w, {{ section.settings.banner_image | image_url: width: 800 }} 800w"
            sizes="(max-width: 768px) 60vw, 40vw"
            alt="{{ section.settings.banner_line_1 }} {{ section.settings.banner_line_2 }}"
            class="object-contain object-bottom"
            style="max-height: 85%; max-width: 40%; width: auto;"
            loading="lazy" width="800" height="1000" decoding="async"
          >
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sobre Nosotros",
  "tag": "div",
  "class": "about-page",
  "settings": [
    {
      "type": "header",
      "content": "Manifiesto"
    },
    {
      "type": "text",
      "id": "manifesto_heading",
      "label": "Manifesto Heading",
      "default": "Nuestro Manifiesto"
    },
    {
      "type": "richtext",
      "id": "manifesto_text",
      "label": "Manifesto Text",
      "default": "<p>Hay cosas que no necesitan explicación. Un brindis por lo que fue. Una copa por lo que vendrá. Un \"¡Salud!\" que suena más fuerte cuando se comparte.</p><p>Celebrar está en nuestra naturaleza. Porque la vida no solo se vive, se celebra. Y si celebrar es parte de la vida, cuidarte también debería serlo. No como una restricción, sino como un acto de amor propio. De equilibrio.</p><p>Buenacopa nace de esa idea: De unir el gozo de la celebración con el poder de la ciencia y la conciencia. Buenacopa no es un antídoto. Es una decisión. Una nueva forma de brindar. Con alegría, con conciencia, con equilibrio. Porque lo que empieza con una buena copa… merece terminar con un buen día. Buenacopa. Buenos días.</p>"
    },
    {
      "type": "image_picker",
      "id": "manifesto_image",
      "label": "Manifesto Image"
    },
    {
      "type": "header",
      "content": "Historia / Misión / Visión"
    },
    {
      "type": "image_picker",
      "id": "story_image",
      "label": "Story Section Image"
    },
    {
      "type": "text",
      "id": "history_heading",
      "label": "History Heading",
      "default": "Nuestra Historia"
    },
    {
      "type": "textarea",
      "id": "history_text",
      "label": "History Text",
      "default": "Buenacopa surgió de nuestras propias experiencias con DHM (Dihidromiricetina) y su sorprendente efectividad. Inspirados por los resultados, decidimos crear la primera solución post-fiesta con respaldo científico en México, una que promueve una relación equilibrada con el alcohol y respeta tanto los momentos de alegría como el bienestar del día siguiente."
    },
    {
      "type": "text",
      "id": "mission_heading",
      "label": "Mission Heading",
      "default": "Nuestra Misión"
    },
    {
      "type": "textarea",
      "id": "mission_text",
      "label": "Mission Text",
      "default": "Apoyamos la celebración consciente ofreciendo productos con respaldo científico que ayudan a mantener el equilibrio entre el disfrute y el bienestar personal. Buscamos transformar la relación de los mexicanos con el alcohol, promoviendo el cuidado personal como parte integral de la experiencia de celebración."
    },
    {
      "type": "text",
      "id": "vision_heading",
      "label": "Vision Heading",
      "default": "Nuestra Visión"
    },
    {
      "type": "textarea",
      "id": "vision_text",
      "label": "Vision Text",
      "default": "Convertirnos en la marca más confiable y accesible de México en bienestar post-fiesta, haciendo posible que más personas disfruten plenamente de la vida sin sacrificar el día siguiente."
    },
    {
      "type": "header",
      "content": "Valores"
    },
    {
      "type": "text",
      "id": "values_subheading",
      "label": "Values Subheading",
      "default": "Lo que creemos define lo que creamos"
    },
    {
      "type": "text",
      "id": "values_heading",
      "label": "Values Heading",
      "default": "Nuestros Valores"
    },
    {
      "type": "textarea",
      "id": "values_description",
      "label": "Values Description",
      "default": "Cada decisión detrás de BUENACOPA nace de nuestros valores. No hacemos atajos, hacemos lo correcto."
    },
    {
      "type": "header",
      "content": "Compromiso"
    },
    {
      "type": "text",
      "id": "commitment_heading",
      "label": "Commitment Heading",
      "default": "Nuestro Compromiso"
    },
    {
      "type": "richtext",
      "id": "commitment_text",
      "label": "Commitment Text",
      "default": "<p>Creemos que está surgiendo una nueva forma de relacionarnos con la celebración – una que honra su lugar en nuestra cultura pero que también prioriza nuestro bienestar.</p><p>No buscamos cambiar la forma en que socializas, sino complementarla con el cuidado personal. Queremos ser el puente entre disfrutar plenamente tus noches y despertar con energía para aprovechar tus días.</p><p>Porque creemos que los momentos de celebración son valiosos, pero también lo son las mañanas productivas, los entrenamientos energéticos y las mentes despejadas.</p><p>Únete a nosotros en este camino hacia un equilibrio entre la vida social y el bienestar personal. Con Buenacopa, puedes decir sí a ambos.</p>"
    },
    {
      "type": "text",
      "id": "commitment_cta_text",
      "label": "CTA Button Text",
      "default": "Comprar ahora"
    },
    {
      "type": "url",
      "id": "commitment_cta_url",
      "label": "CTA Button URL"
    },
    {
      "type": "image_picker",
      "id": "commitment_image_1",
      "label": "Collage Image 1 (top-left)"
    },
    {
      "type": "image_picker",
      "id": "commitment_image_2",
      "label": "Collage Image 2 (top-right)"
    },
    {
      "type": "image_picker",
      "id": "commitment_image_3",
      "label": "Collage Image 3 (bottom)"
    },
    {
      "type": "header",
      "content": "Banner Final"
    },
    {
      "type": "text",
      "id": "banner_line_1",
      "label": "Banner Line 1",
      "default": "Buenacopa"
    },
    {
      "type": "text",
      "id": "banner_line_2",
      "label": "Banner Line 2",
      "default": "Buenos días"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Person Image"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "balance", "label": "Balance (Equilibrio)" },
            { "value": "science", "label": "Science (Ciencia)" },
            { "value": "responsibility", "label": "Shield (Responsabilidad)" },
            { "value": "innovation", "label": "Lightbulb (Innovación)" },
            { "value": "wellness", "label": "Heart (Bienestar)" },
            { "value": "accessibility", "label": "People (Accesibilidad)" }
          ],
          "default": "balance"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Valor"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sobre Nosotros",
      "blocks": [
