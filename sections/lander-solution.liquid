{%- comment -%}
  Lander Solution — Outcome-first, not ingredient-first.
  "Sell the morning, not the capsule."
  Heading + 3 checkmark outcomes + optional lifestyle image.
{%- endcomment -%}

<section class="overflow-hidden" style="padding: 3rem 0; background-color: #ffffff;">
  <div class="container-custom">

    {%- comment -%}Section label{%- endcomment -%}
    {% if section.settings.label != blank %}
      <p class="font-bold uppercase tracking-wider text-center" style="font-size: 11px; letter-spacing: 0.1em; margin-bottom: 6px; color: rgba(7,29,64,0.4);">
        {{ section.settings.label }}
      </p>
    {% endif %}

    <h2 class="font-display font-black text-center" style="font-size: clamp(1.5rem, 5vw, 2.25rem); line-height: 1.1; max-width: 520px; margin: 0 auto; color: #001D45;">
      {{ section.settings.heading | default: 'Buenacopa trabaja mientras duermes' }}
    </h2>

    {%- comment -%}Outcome checklist{%- endcomment -%}
    <div class="mx-auto" style="max-width: 400px; margin-top: 24px;">
      {% for i in (1..3) %}
        {%- capture outcome_key -%}outcome_{{ i }}{%- endcapture -%}
        {%- assign outcome_text = section.settings[outcome_key] -%}
        {% if outcome_text != blank %}
          <div class="flex items-center gap-3" style="padding: 10px 0;">
            <div class="shrink-0 flex items-center justify-center rounded-full" style="width: 28px; height: 28px; background-color: rgba(0,171,67,0.1);">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#00A33C" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span class="font-bold" style="font-size: 16px; color: #001D45;">{{ outcome_text }}</span>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {%- comment -%}Lifestyle image (morning after) — customizer image or fallback to step-03-despierta{%- endcomment -%}
    <div class="mx-auto rounded-2xl overflow-hidden" style="max-width: 480px; margin-top: 24px;">
      {% if section.settings.image %}
        <img
          src="{{ section.settings.image | image_url: width: 960 }}"
          srcset="{{ section.settings.image | image_url: width: 480 }} 480w, {{ section.settings.image | image_url: width: 960 }} 960w"
          sizes="(max-width: 768px) 100vw, 480px"
          alt="{{ section.settings.image_alt | default: 'Morning after — energized' }}"
          class="w-full h-auto"
          style="aspect-ratio: 4/3; object-fit: cover;"
          width="480" height="360"
          loading="lazy"
          decoding="async"
        >
      {% else %}
        <img
          src="{{ 'lander-solution-lifestyle.jpg' | asset_url }}"
          alt="Morning energy"
          class="w-full h-auto"
          style="aspect-ratio: 4/3; object-fit: cover;"
          width="480" height="360"
          loading="lazy"
          decoding="async"
        >
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lander Solution",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "RESULTADOS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Buenacopa trabaja mientras duermes"
    },
    {
      "type": "text",
      "id": "outcome_1",
      "label": "Outcome 1",
      "default": "Despierta con energía real"
    },
    {
      "type": "text",
      "id": "outcome_2",
      "label": "Outcome 2",
      "default": "Sin dolor de cabeza ni náuseas"
    },
    {
      "type": "text",
      "id": "outcome_3",
      "label": "Outcome 3",
      "default": "Listo para lo que sigue"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle Image (optional)"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image Alt Text",
      "default": "Morning after — energized"
    }
  ],
  "presets": [
    {
      "name": "Lander Solution"
    }
  ]
}
{% endschema %}
