<section class="py-8 md:py-10 px-4 sm:px-6 md:px-8 bg-background">
  <div class="container-custom text-center">
    <p style="font-family: 'Inter', sans-serif; font-size: 13px; color: rgba(255,255,255,0.5); font-weight: 500; margin-bottom: 16px;">
      {{ section.settings.heading | default: 'También disponible en:' }}
    </p>
    <div class="flex items-center justify-center gap-8 md:gap-12">
      {% for block in section.blocks %}
        {% if block.type == 'marketplace' %}
          <a href="{{ block.settings.url }}" target="_blank" rel="noopener noreferrer" data-track-placement="available-in" class="flex items-center justify-center hover:opacity-70 transition-opacity" style="opacity: 0.5;" {{ block.shopify_attributes }}>
            {% if block.settings.logo %}
              <img src="{{ block.settings.logo | image_url: width: 288 }}" alt="{{ block.settings.label }}" width="{{ block.settings.logo.width }}" height="{{ block.settings.logo.height }}" style="height: 36px; width: auto; object-fit: contain;" loading="lazy" decoding="async">
            {% else %}
              <span class="text-foreground font-bold" style="font-size: 14px;">{{ block.settings.label }}</span>
            {% endif %}
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Available In",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "También disponible en:"
    }
  ],
  "blocks": [
    {
      "type": "marketplace",
      "name": "Marketplace",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Available In",
      "blocks": [
        { "type": "marketplace", "settings": { "label": "Amazon", "url": "https://www.amazon.com.mx/stores/page/FDB18C6D-10B7-43A2-AA75-D935DEF10C38?channel=BOTONSITIOWEB" } },
        { "type": "marketplace", "settings": { "label": "Mercado Libre", "url": "https://www.mercadolibre.com.mx/tienda/buenacopa" } }
      ]
    }
  ]
}
{% endschema %}
