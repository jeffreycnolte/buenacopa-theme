{%- comment -%}
  Lander Ingredients — Clean, simple, punchy.
  "Satisfy the wellness-minded buyer. Keep it punchy — not a science lecture."
  Simple vertical list with inline SVG icons. No background images, no cards.
{%- endcomment -%}

<section class="overflow-hidden" style="padding: 3rem 0; background-color: #FAF7F2;">
  <div class="container-custom">

    {%- comment -%}Section label + heading{%- endcomment -%}
    {% if section.settings.label != blank %}
      {% render 'brand/section-label', text: section.settings.label, align: 'center' %}
    {% endif %}

    <h2 class="font-display font-black text-center" style="font-size: clamp(1.5rem, 5vw, 2.25rem); line-height: 1.1; color: #001D45; margin-bottom: 32px;">
      {{ section.settings.heading | default: 'Lo que hay adentro importa.' }}
    </h2>

    {%- comment -%}Ingredient list — simple rows{%- endcomment -%}
    <div class="mx-auto" style="max-width: 480px;">
      {% for block in section.blocks %}
        {% if block.type == 'ingredient' %}
          <div style="{% unless forloop.first %}margin-top: 20px; padding-top: 20px; border-top: 1px solid rgba(7,29,64,0.08);{% endunless %}" {{ block.shopify_attributes }}>
            <div class="flex items-start gap-4">
              {%- comment -%}Simple icon — pill, shield, or leaf based on ingredient type{%- endcomment -%}
              <div class="shrink-0 flex items-center justify-center rounded-xl" style="width: 44px; height: 44px; background-color: rgba(0,171,67,0.08);">
                {% case block.settings.icon_type %}
                  {% when 'brain' %}
                    {%- comment -%}Brain/neuro icon for DHM{%- endcomment -%}
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#00A33C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7z"/>
                      <path d="M10 21h4"/>
                      <path d="M12 2v5"/>
                      <path d="M9.5 7L12 9.5 14.5 7"/>
                    </svg>
                  {% when 'shield' %}
                    {%- comment -%}Shield icon for L-Cisteína{%- endcomment -%}
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#00A33C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                      <polyline points="9 12 11 14 15 10"/>
                    </svg>
                  {% when 'leaf' %}
                    {%- comment -%}Leaf/natural icon for Vit C + Cúrcuma{%- endcomment -%}
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#00A33C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66.95-2.3c.48.17.98.3 1.34.3C19 20 22 3 22 3c-1 2-8 2.25-13 3.25S2 11.5 2 13.5s1.75 3.75 1.75 3.75"/>
                    </svg>
                  {% else %}
                    {%- comment -%}Default capsule icon{%- endcomment -%}
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#00A33C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5A2.25 2.25 0 0 0 8.25 22.5h7.5A2.25 2.25 0 0 0 18 20.25V3.75A2.25 2.25 0 0 0 15.75 1.5H13.5m-3 0V3h3V1.5m-3 0h3m-6 9h9"/>
                    </svg>
                {% endcase %}
              </div>

              <div>
                {%- comment -%}Ingredient name as a bold inline badge{%- endcomment -%}
                <span class="font-display font-black" style="font-size: 17px; color: #001D45;">
                  {{ block.settings.title }}
                </span>
                {% if block.settings.subtitle != blank %}
                  <span style="font-size: 12px; color: rgba(7,29,64,0.4); margin-left: 6px;">{{ block.settings.subtitle }}</span>
                {% endif %}

                {% if block.settings.description != blank %}
                  <p style="font-size: 14px; color: rgba(7,29,64,0.6); margin-top: 4px; line-height: 1.5;">
                    {{ block.settings.description }}
                  </p>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {%- comment -%}Footer tagline — credibility markers{%- endcomment -%}
    {% if section.settings.tagline != blank %}
      <div class="text-center" style="margin-top: 28px;">
        <p style="font-size: 12px; color: rgba(7,29,64,0.4); font-weight: 500; max-width: 400px; margin: 0 auto; line-height: 1.6;">
          {{ section.settings.tagline }}
        </p>
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Lander Ingredients",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "LA FÓRMULA"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Lo que hay adentro importa."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Footer Tagline",
      "default": "Sin cafeína · Sin azúcar · Fabricado GMP · Regulado por COFEPRIS"
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "DHM"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle (optional)"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "select",
          "id": "icon_type",
          "label": "Icon",
          "options": [
            { "value": "brain", "label": "Brain (DHM)" },
            { "value": "shield", "label": "Shield (protection)" },
            { "value": "leaf", "label": "Leaf (natural)" },
            { "value": "capsule", "label": "Capsule (default)" }
          ],
          "default": "capsule"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lander Ingredients",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "title": "DHM",
            "subtitle": "Dihidromiricetina",
            "description": "Acelera el metabolismo del alcohol. Reduce la ansiedad post-fiesta.",
            "icon_type": "brain"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "title": "L-Cisteína",
            "description": "Neutraliza toxinas. Menos náuseas, menos daño.",
            "icon_type": "shield"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "title": "Vitamina C + Cúrcuma",
            "description": "Antioxidantes que trabajan de noche.",
            "icon_type": "leaf"
          }
        }
      ]
    }
  ]
}
{% endschema %}
