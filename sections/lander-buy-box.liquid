{%- comment -%}
  Lander Buy Box — Uses the canonical brand-buybox snippet.
  Single-SKU model: one one-time variant + one optional subscription.
  Section file is the controller — does all Shopify-data work, then passes
  pre-shaped scalars to the view snippet.
{%- endcomment -%}

{%- comment -%}
  Product resolution priority:
    1. The current page's product (when viewed via /products/<handle>) —
       so a product with theme template = "lander" auto-renders its own data.
    2. The section's explicit product setting — for cases where this section
       is dropped on a non-product page (e.g. a regular page template).
    3. Fallback to collections.all.products.first.
  Note: when on a product page, the global `product` is already set.
{%- endcomment -%}
{%- if product == blank -%}
  {%- assign product = section.settings.product | default: collections.all.products.first -%}
{%- endif -%}

{%- liquid
  # Subscription detection: first selling plan + the variant it's allocated to.
  assign has_subscription = false
  assign sub_variant = nil
  assign sub_plan = nil
  assign sub_price = 0

  # --- Subscription source resolution -----------------------------------------
  # Default: read sub_variant + plan from the page's product (the standard case
  # for /products/X where X is a regular product with a Recharge plan).
  #
  # Override: section setting `subscription_source_product` lets the lander pull
  # sub_variant + plan from a DIFFERENT product. Used when the page product is
  # a Shopify Bundle (which can't accept selling_plan line items via
  # /cart/add.js — 422 "del paquete"). Sub tile click then adds the override
  # product's variant + plan, bypassing the bundle limitation while the
  # one-time tile still uses the bundle for inventory sharing.
  # ------------------------------------------------------------------------------
  assign sub_source = section.settings.subscription_source_product
  if sub_source == blank
    assign sub_source = product
  endif

  # Plan resolution within the source product:
  #   - If `subscription_plan_id` section setting is set, find that specific
  #     plan (used when a product has multiple plans and we want a specific
  #     one — e.g. Bienvenida's multi-tier 36%-first / 20%-ongoing plan
  #     attached to the main product variant alongside the evergreen 20%
  #     flat plan).
  #   - Otherwise, fall back to the first plan in the first group.
  assign target_plan_id_str = section.settings.subscription_plan_id
  assign target_plan_id = 0
  if target_plan_id_str != blank
    assign target_plan_id = target_plan_id_str | plus: 0
  endif

  for group in sub_source.selling_plan_groups
    if group.selling_plans.size > 0
      for plan in group.selling_plans
        if target_plan_id == 0 or plan.id == target_plan_id
          assign sub_plan = plan
          break
        endif
      endfor
      if sub_plan
        assign has_subscription = true
        for variant in sub_source.variants
          for allocation in variant.selling_plan_allocations
            if allocation.selling_plan.id == sub_plan.id
              assign sub_variant = variant
              assign sub_price = allocation.price
              break
            endif
          endfor
          if sub_variant
            break
          endif
        endfor
        break
      endif
    endif
  endfor

  # Tag-based suppression: only applies when no explicit override product is set.
  # If you've configured a subscription_source_product, you've already bypassed
  # the bundle limitation, so the tag check shouldn't second-guess that.
  if section.settings.subscription_source_product == blank
    if product.tags contains 'bundle' or product.tags contains 'no-subscription'
      assign has_subscription = false
    endif
  endif

  # One-time variant: first available variant (single-SKU model).
  # Falls back to first variant if none are available so the tile still renders.
  assign onetime_variant = nil
  for variant in product.variants
    if variant.available
      assign onetime_variant = variant
      break
    endif
  endfor
  if onetime_variant == nil
    assign onetime_variant = product.variants.first
  endif

  # Servings: parse first numeric token from the one-time variant title.
  assign servings = 0
  if onetime_variant
    assign title_words = onetime_variant.title | split: ' '
    for word in title_words
      assign word_num = word | plus: 0
      if word_num > 0
        assign servings = word_num
        break
      endif
    endfor
  endif
  if servings == 0
    assign servings = 10
  endif

  # Subscription price math
  assign sub_price_whole = sub_price | divided_by: 100
  assign sub_price_cents = sub_price | modulo: 100
  if sub_price > 0 and servings > 0
    assign sub_per_serving = sub_price | divided_by: servings
  else
    assign sub_per_serving = 0
  endif
  assign sub_per_whole = sub_per_serving | divided_by: 100

  # One-time price math
  assign ot_price = onetime_variant.price | default: 0
  assign ot_compare = onetime_variant.compare_at_price | default: 0
  assign ot_price_whole = ot_price | divided_by: 100
  assign ot_price_cents = ot_price | modulo: 100
  assign ot_compare_whole = ot_compare | divided_by: 100
  if ot_price > 0 and servings > 0
    assign ot_per_serving = ot_price | divided_by: servings
  else
    assign ot_per_serving = 0
  endif
  assign ot_per_whole = ot_per_serving | divided_by: 100

  # Subscription strikethrough anchor: use the retail price (compare_at) when
  # the variant is already discounted (Bienvenida case), else the variant's
  # regular price (evergreen case where the variant IS retail). Always shows
  # the strongest legitimate anchor above the sub price.
  if ot_compare > ot_price
    assign sub_compare_whole = ot_compare_whole
  else
    assign sub_compare_whole = ot_price_whole
  endif

  # Monthly savings vs one-time, rounded to nearest peso for display.
  assign sub_savings_total = 0
  if ot_price > sub_price
    assign sub_savings_total = ot_price | minus: sub_price
  endif
  assign sub_savings_whole = sub_savings_total | plus: 50 | divided_by: 100

  # Multi-tier Recharge plan detection: "20% off first N orders, then 0%"
  # produces a different first-month price than the recurring price.
  # Spec for Meta lander: variant \$519.20 + Recharge "20% off first 1 order"
  #   → first month \$519.20 × 0.80 = \$415.36
  #   → recurring   \$519.20 (Recharge plan exhausted, falls back to variant price)
  assign sub_is_multi_tier = false
  assign sub_recurring_price = sub_price
  if sub_plan and sub_plan.price_adjustments.size > 1
    assign sub_is_multi_tier = true
    assign last_adj = sub_plan.price_adjustments.last
    if last_adj.value_type == 'percentage'
      assign factor = 100 | minus: last_adj.value
      assign sub_recurring_price = onetime_variant.price | times: factor | divided_by: 100
    elsif last_adj.value_type == 'fixed_amount'
      assign sub_recurring_price = onetime_variant.price | minus: last_adj.value
    elsif last_adj.value_type == 'price'
      assign sub_recurring_price = last_adj.value
    endif
  endif
  assign sub_recurring_whole = sub_recurring_price | divided_by: 100
  assign sub_recurring_cents = sub_recurring_price | modulo: 100

  # First-month savings vs retail (compare_at_price). Used for the "AHORRA X% PRIMER MES"
  # pill and the "Ahorras \$X el primer mes" bullet. Falls back to ot_price if no compare-at.
  assign retail_anchor = ot_compare
  if retail_anchor == 0
    assign retail_anchor = ot_price
  endif
  assign sub_first_savings_total = 0
  if retail_anchor > sub_price
    assign sub_first_savings_total = retail_anchor | minus: sub_price
  endif
  assign sub_first_savings_whole = sub_first_savings_total | plus: 50 | divided_by: 100
  assign sub_first_savings_pct = 0
  if retail_anchor > 0
    # ((retail - sub_price) * 100) / retail, with round-to-nearest via +half-divisor.
    assign half = retail_anchor | divided_by: 2
    assign sub_first_savings_pct = sub_first_savings_total | times: 100 | plus: half | divided_by: retail_anchor
  endif
-%}

<section id="lander-buy-box" class="overflow-hidden bg-white" style="padding: 2.5rem 0;">
  <div class="container-custom">

    {%- comment -%}Section heading{%- endcomment -%}
    <div class="text-center" style="margin-bottom: 16px;">
      <p class="font-bold text-accent uppercase tracking-wider" style="font-size: 11px; letter-spacing: 0.1em; margin-bottom: 4px;">
        {{ section.settings.label | default: 'ELIGE TU PLAN' }}
      </p>
      <h2 class="font-display font-black text-background" style="font-size: clamp(1.5rem, 4vw, 2rem);">
        {{ section.settings.heading | default: 'Elige tu plan' }}
      </h2>
    </div>

    {%- comment -%}Product image{%- endcomment -%}
    {% if product.featured_image %}
      <div class="mx-auto rounded-2xl overflow-hidden" style="max-width: 340px; margin-bottom: 20px;">
        <img
          src="{{ product.featured_image | image_url: width: 800 }}"
          srcset="{{ product.featured_image | image_url: width: 400 }} 400w, {{ product.featured_image | image_url: width: 800 }} 800w"
          sizes="(max-width: 768px) 85vw, 340px"
          alt="{{ product.title }}"
          class="w-full h-auto"
          style="aspect-ratio: 1/1; object-fit: cover;"
          width="340" height="340"
          loading="lazy"
          decoding="async"
        >
      </div>
    {% endif %}

    {%- comment -%}
      Translation strings — pre-assign because filters don't always evaluate
      inline in render-tag arguments.
    {%- endcomment -%}
    {%- assign t_ssl = 'general.security.ssl_badge' | t -%}
    {%- assign t_shipping = 'general.security.free_shipping_badge' | t -%}
    {%- assign t_guarantee = 'general.security.guarantee_badge' | t -%}

    {% render 'brand-buybox',
      id_prefix: 'lander',
      product_id: product.id,
      has_subscription: has_subscription,
      sub_variant_id: sub_variant.id,
      sub_plan_id: sub_plan.id,
      sub_price_raw: sub_price,
      sub_servings: servings,
      sub_price_whole: sub_price_whole,
      sub_price_cents: sub_price_cents,
      sub_compare_whole: sub_compare_whole,
      sub_per_whole: sub_per_whole,
      sub_savings_whole: sub_savings_whole,
      sub_is_multi_tier: sub_is_multi_tier,
      sub_recurring_whole: sub_recurring_whole,
      sub_recurring_cents: sub_recurring_cents,
      sub_first_savings_whole: sub_first_savings_whole,
      sub_first_savings_pct: sub_first_savings_pct,
      onetime_variant_id: onetime_variant.id,
      onetime_variant_title: onetime_variant.title,
      onetime_price_raw: ot_price,
      onetime_price_whole: ot_price_whole,
      onetime_price_cents: ot_price_cents,
      onetime_compare_whole: ot_compare_whole,
      onetime_per_whole: ot_per_whole,
      onetime_available: onetime_variant.available,
      trust_ssl: t_ssl,
      trust_shipping: t_shipping,
      trust_guarantee: t_guarantee
    %}
  </div>
</section>

<script>
// Selection visuals + cart wiring are handled by ProductForm (assets/product-form.js).
// The lander shares the same JS as the homepage buy-box; no extra wiring needed here.
</script>

{% schema %}
{
  "name": "Lander Buy Box",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "ELIGE TU PLAN"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Elige tu plan"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "header",
      "content": "Subscription source override"
    },
    {
      "type": "product",
      "id": "subscription_source_product",
      "label": "Subscription source product",
      "info": "Optional. Use when the page product is a Shopify Bundle (which can't accept subscription line items via the cart API). The sub tile will pull its variant + plan from this product instead. Leave blank for normal products."
    },
    {
      "type": "text",
      "id": "subscription_plan_id",
      "label": "Subscription plan ID (optional)",
      "info": "Optional. When the source product has multiple selling plans (e.g. an evergreen flat 20% plan + an acquisition multi-tier 36%-first / 20%-ongoing plan), this picks the specific plan to use for the sub tile. Leave blank to use the first plan."
    }
  ],
  "presets": [
    {
      "name": "Lander Buy Box"
    }
  ]
}
{% endschema %}
