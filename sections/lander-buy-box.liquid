{%- comment -%}
  Lander Buy Box — Uses the same purchase module as the homepage product-hero.
  Adds: "Elige tu plan" heading, larger product image above.
  Removes: carousel, dropdowns, thumbnails.
  Uses theme CSS classes (text-background, border-accent, etc.) that are in compiled Tailwind.
{%- endcomment -%}

{%- assign product = section.settings.product -%}
{%- if product == blank -%}
  {%- assign product = collections.all.products.first -%}
{%- endif -%}

{%- liquid
  assign has_subscription = false
  assign sub_variant = nil
  assign sub_plan = nil
  assign sub_price = 0
  assign sub_servings = 0

  for group in product.selling_plan_groups
    if group.selling_plans.size > 0
      assign has_subscription = true
      assign sub_plan = group.selling_plans[0]
      for variant in product.variants
        for allocation in variant.selling_plan_allocations
          if allocation.selling_plan.id == sub_plan.id
            assign sub_variant = variant
            assign sub_price = allocation.price
            break
          endif
        endfor
        if sub_variant
          break
        endif
      endfor
      break
    endif
  endfor

  if sub_variant
    assign sub_title_words = sub_variant.title | split: ' '
    for word in sub_title_words
      assign word_num = word | plus: 0
      if word_num > 0
        assign sub_servings = word_num
        break
      endif
    endfor
  endif
  if sub_servings == 0
    assign sub_servings = 1
  endif

  if sub_price > 0 and sub_servings > 0
    assign sub_per_serving = sub_price | divided_by: sub_servings
  else
    assign sub_per_serving = 0
  endif

  assign sub_price_whole = sub_price | divided_by: 100
  assign sub_price_cents = sub_price | modulo: 100
  assign sub_per_whole = sub_per_serving | divided_by: 100

  assign sub_compare_price = 0
  for variant in product.variants
    assign v_title_lower = variant.title | downcase
    unless v_title_lower contains 'suscri'
      assign v_words = variant.title | split: ' '
      for w in v_words
        assign w_num = w | plus: 0
        if w_num == sub_servings
          assign sub_compare_price = variant.price
          break
        endif
      endfor
    endunless
    if sub_compare_price > 0
      break
    endif
  endfor
  assign sub_compare_whole = sub_compare_price | divided_by: 100
-%}

<section id="lander-buy-box" class="overflow-hidden bg-white" style="padding: 2.5rem 0;">
  <div class="container-custom">

    {%- comment -%}Section heading{%- endcomment -%}
    <div class="text-center" style="margin-bottom: 16px;">
      <p class="font-bold text-accent uppercase tracking-wider" style="font-size: 11px; letter-spacing: 0.1em; margin-bottom: 4px;">
        {{ section.settings.label | default: 'ELIGE TU PLAN' }}
      </p>
      <h2 class="font-display font-black text-background" style="font-size: clamp(1.5rem, 4vw, 2rem);">
        {{ section.settings.heading | default: 'Elige tu plan' }}
      </h2>
    </div>

    {%- comment -%}Product image — bigger than before{%- endcomment -%}
    {% if product.featured_image %}
      <div class="mx-auto rounded-2xl overflow-hidden" style="max-width: 340px; margin-bottom: 20px;">
        <img
          src="{{ product.featured_image | image_url: width: 800 }}"
          srcset="{{ product.featured_image | image_url: width: 400 }} 400w, {{ product.featured_image | image_url: width: 800 }} 800w"
          sizes="(max-width: 768px) 85vw, 340px"
          alt="{{ product.title }}"
          class="w-full h-auto"
          style="aspect-ratio: 1/1; object-fit: cover;"
          width="340" height="340"
          loading="lazy"
          decoding="async"
        >
      </div>
    {% endif %}

    {%- comment -%}Purchase flow — matches homepage product-hero exactly{%- endcomment -%}
    <div class="space-y-3 mx-auto" style="max-width: 520px;" id="lander-product-form" data-product-id="{{ product.id }}">

      <!-- Shipping badge -->
      <div class="flex items-center gap-2 text-background/50">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        <span style="font-size:12px" class="font-medium">Envíos a todo México</span>
      </div>

      {%- comment -%}═══ SUBSCRIPTION CARD — same as homepage ═══{%- endcomment -%}
      {% if has_subscription and sub_variant %}
        <div
          id="lander-subscription-card"
          class="relative rounded-xl border-2 border-accent cursor-pointer transition-all"
          style="background: linear-gradient(180deg, rgba(0,171,67,0.06) 0%, rgba(0,171,67,0.02) 100%); padding: 24px 16px 14px;"
          onclick="ProductForm.selectSubscription({{ sub_variant.id }}, {{ sub_plan.id }})"
          data-variant-id="{{ sub_variant.id }}"
          data-selling-plan-id="{{ sub_plan.id }}"
          data-price="{{ sub_price }}"
        >
          {% render 'brand/badge', variant: 'best-value', text: 'MEJOR VALOR', class_extra: 'absolute left-3', style_extra: 'top:-11px;' %}

          <div class="flex items-baseline justify-between">
            <p class="font-bold text-background" style="font-size:14px">Suscripción ({{ sub_servings }} sobres)</p>
            <div style="text-align:right; white-space:nowrap;">
              {%- if sub_compare_price > sub_price -%}
                <span style="font-size:13px; color:rgba(7,29,64,0.4); text-decoration:line-through; font-weight:600; margin-right:4px;">${{ sub_compare_whole }}</span>
              {%- endif -%}
              <span class="font-display font-black text-background" style="font-size:22px">${{ sub_price_whole }}</span>{%- if sub_price_cents > 0 -%}<span class="font-display font-black text-background" style="font-size:14px">.{{ sub_price_cents }}</span>{%- endif -%}<span style="font-size:11px; color:rgba(7,29,64,0.4); font-weight:600; margin-left:2px">/mes</span>
            </div>
          </div>

          <div class="grid grid-cols-2" style="margin-top:8px; gap:3px 12px">
            <div style="display:flex; align-items:center; gap:6px">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" aria-hidden="true" class="shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
              <span style="font-size:11px; color:rgba(7,29,64,0.65)"><strong>40% off primeros 2 meses</strong></span>
            </div>
            <div style="display:flex; align-items:center; gap:6px">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" aria-hidden="true" class="shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
              <span style="font-size:11px; color:rgba(7,29,64,0.65)"><strong>15% off de por vida</strong></span>
            </div>
            <div style="display:flex; align-items:center; gap:6px">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" aria-hidden="true" class="shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
              <span style="font-size:11px; color:rgba(7,29,64,0.65)">${{ sub_per_whole }} por toma</span>
            </div>
            <div style="display:flex; align-items:center; gap:6px">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" aria-hidden="true" class="shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
              <span style="font-size:11px; color:rgba(7,29,64,0.65)">Cancela cuando quieras</span>
            </div>
          </div>

          <button
            onclick="event.stopPropagation(); ProductForm.selectSubscription({{ sub_variant.id }}, {{ sub_plan.id }}); ProductForm.addToCart();"
            class="w-full btn-cta flex items-center justify-center gap-2"
            style="margin-top:14px; font-size:14px; padding:10px 0"
          >
            Suscribirme ahora
            <span class="inline-flex">{% render 'icon-arrow-right', size: 16 %}</span>
          </button>
        </div>
      {% endif %}

      {%- comment -%}═══ ONE-TIME PURCHASE — same as homepage ═══{%- endcomment -%}
      <div>
        <div class="flex items-center gap-3" style="margin-top:4px">
          <p class="font-bold text-background shrink-0" style="font-size:14px">Compra única</p>
          <div class="flex-1 h-px bg-background/10"></div>
        </div>

        <div id="lander-variant-selector">
          {%- comment -%}First row: 2-column grid for smaller variants{%- endcomment -%}
          <div class="grid grid-cols-2 gap-2" style="margin-top:8px">
            {%- assign rendered = 0 -%}
            {%- for variant in product.variants -%}
              {%- liquid
                assign variant_title_lower = variant.title | downcase
                assign is_sub_only = false
                if variant_title_lower contains 'suscripción' or variant_title_lower contains 'suscripcion' or variant_title_lower contains 'subscription'
                  assign is_sub_only = true
                endif
                assign servings = 0
                assign title_words = variant.title | split: ' '
                for word in title_words
                  assign word_as_number = word | plus: 0
                  if word_as_number > 0
                    assign servings = word_as_number
                    break
                  endif
                endfor
                if servings == 0
                  assign servings = 1
                endif
                if variant.price > 0 and servings > 0
                  assign per_serving = variant.price | divided_by: servings
                else
                  assign per_serving = 0
                endif
              -%}
              {%- unless is_sub_only -%}
                {%- assign rendered = rendered | plus: 1 -%}
                {%- if rendered <= 2 -%}
                  <button
                    type="button"
                    onclick="ProductForm.selectOneTime({{ variant.id }}, this)"
                    data-variant-id="{{ variant.id }}"
                    data-variant-price="{{ variant.price }}"
                    data-variant-available="{{ variant.available }}"
                    class="variant-btn flex items-center justify-between rounded-xl border-2 transition-all duration-200 border-background/15 bg-background/5 hover:border-background/25 {% unless variant.available %}opacity-50 cursor-not-allowed{% endunless %}"
                    style="padding:10px 12px"
                    {% unless variant.available %}disabled{% endunless %}
                  >
                    <span class="font-bold text-background" style="font-size:13px">{{ variant.title }}</span>
                    <div style="text-align:right">
                      {%- assign v_whole = variant.price | divided_by: 100 -%}
                      {%- capture v_formatted -%}{%- if v_whole >= 1000 -%}{{ v_whole | divided_by: 1000 }},{{ v_whole | modulo: 1000 | prepend: '000' | slice: -3, 3 }}{%- else -%}{{ v_whole }}{%- endif -%}{%- endcapture -%}
                      {% if variant.compare_at_price > variant.price %}
                        {%- assign cap_whole = variant.compare_at_price | divided_by: 100 -%}
                        <span class="text-background/30" style="font-size:11px; text-decoration:line-through">${{ cap_whole }}</span>
                      {% endif %}
                      <span class="font-display font-black text-background" style="font-size:15px">${{ v_formatted }}</span>
                      {% if per_serving > 0 %}
                        {%- assign ps_whole = per_serving | divided_by: 100 -%}
                        <div class="text-background/40" style="font-size:9px; text-align:right">${{ ps_whole }}/toma</div>
                      {% endif %}
                    </div>
                  </button>
                {%- endif -%}
              {%- endunless -%}
            {%- endfor -%}
          </div>

          {%- comment -%}Second row: full-width for 20 sobres{%- endcomment -%}
          {%- assign rendered = 0 -%}
          {%- for variant in product.variants -%}
            {%- liquid
              assign variant_title_lower = variant.title | downcase
              assign is_sub_only = false
              if variant_title_lower contains 'suscripción' or variant_title_lower contains 'suscripcion' or variant_title_lower contains 'subscription'
                assign is_sub_only = true
              endif
              assign servings = 10
              if variant_title_lower contains '20'
                assign servings = 20
              elsif variant_title_lower contains '30'
                assign servings = 30
              elsif variant_title_lower contains '5 '
                assign servings = 5
              endif
              if variant.price > 0 and servings > 0
                assign per_serving = variant.price | divided_by: servings
              else
                assign per_serving = 0
              endif
            -%}
            {%- unless is_sub_only -%}
              {%- assign rendered = rendered | plus: 1 -%}
              {%- if rendered > 2 -%}
                <button
                  type="button"
                  onclick="ProductForm.selectOneTime({{ variant.id }}, this)"
                  data-variant-id="{{ variant.id }}"
                  data-variant-price="{{ variant.price }}"
                  data-variant-available="{{ variant.available }}"
                  class="variant-btn w-full flex items-center justify-between rounded-xl border-2 transition-all duration-200 text-left border-background/15 bg-background/5 hover:border-background/25 {% unless variant.available %}opacity-50 cursor-not-allowed{% endunless %}"
                  style="padding:10px 12px; margin-top:8px; min-height:48px"
                  {% unless variant.available %}disabled{% endunless %}
                >
                  <span class="font-bold text-background" style="font-size:13px">{{ variant.title }}</span>
                  <div style="text-align:right">
                    {%- assign v_whole = variant.price | divided_by: 100 -%}
                    {%- capture v_formatted -%}{%- if v_whole >= 1000 -%}{{ v_whole | divided_by: 1000 }},{{ v_whole | modulo: 1000 | prepend: '000' | slice: -3, 3 }}{%- else -%}{{ v_whole }}{%- endif -%}{%- endcapture -%}
                    <span class="font-display font-black text-background" style="font-size:15px">${{ v_formatted }}</span>
                    {% if per_serving > 0 %}
                      {%- assign ps_whole = per_serving | divided_by: 100 -%}
                      <div class="text-background/40" style="font-size:9px; text-align:right">${{ ps_whole }}/toma</div>
                    {% endif %}
                  </div>
                </button>
              {%- endif -%}
            {%- endunless -%}
          {%- endfor -%}
        </div>

        <!-- Quantity + One-time CTA (hidden until variant selected) -->
        <div id="lander-onetime-cta" class="mt-3" style="display:none;">
          <div style="display:flex; gap:10px; align-items:stretch;">
            <div style="display:flex; align-items:center; border:1px solid rgba(7,29,64,0.15); border-radius:12px; overflow:hidden; flex-shrink:0;">
              <button onclick="ProductForm.decrementQty()" aria-label="Menos" style="padding:10px 14px; background:none; border:none; cursor:pointer; font-size:18px; color:#001D45; font-weight:700; line-height:1;">−</button>
              <span id="lander-product-quantity" style="font-family:'Nunito',sans-serif; font-weight:800; font-size:15px; color:#001D45; min-width:24px; text-align:center;">1</span>
              <button onclick="ProductForm.incrementQty()" aria-label="Más" style="padding:10px 14px; background:none; border:none; cursor:pointer; font-size:18px; color:#001D45; font-weight:700; line-height:1;">+</button>
            </div>
            <button
              onclick="ProductForm.addToCart()"
              class="flex-1 flex items-center justify-center gap-2.5 text-white font-bold text-base rounded-xl transition-colors disabled:opacity-50"
              style="background-color: #00A33C; padding:12px 0;"
              onmouseover="this.style.backgroundColor='#009639'"
              onmouseout="this.style.backgroundColor='#00A33C'"
            >
              Agregar al carrito
            </button>
          </div>
        </div>
      </div>

      <!-- Trust Badges — same as homepage -->
      <div class="flex items-center justify-center text-background/50" id="lander-trust-badges" style="gap:12px; padding:8px 0; font-size:10px">
        <style>@media(min-width:1024px) { #lander-trust-badges { font-size: 12px !important; } #lander-trust-badges svg { width: 14px; height: 14px; } }</style>
        <div class="flex items-center whitespace-nowrap" style="gap:5px; font-weight:500">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="shrink-0"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          {{ 'general.security.ssl_badge' | t }}
        </div>
        <span class="text-background/20">|</span>
        <div class="flex items-center whitespace-nowrap" style="gap:5px; font-weight:500">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="shrink-0"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
          {{ 'general.security.free_shipping_badge' | t }}
        </div>
        <span class="text-background/20">|</span>
        <div class="flex items-center whitespace-nowrap" style="gap:5px; font-weight:500">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="shrink-0"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          {{ 'general.security.guarantee_badge' | t }}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var buyBox = document.getElementById('lander-product-form');
  if (!buyBox) return;

  buyBox.querySelectorAll('.variant-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var ctaRow = document.getElementById('lander-onetime-cta');
      if (ctaRow) ctaRow.style.display = 'block';
      var subCard = document.getElementById('lander-subscription-card');
      if (subCard) {
        subCard.style.borderColor = 'hsl(215 50% 25%)';
        subCard.style.background = 'transparent';
      }
      buyBox.querySelectorAll('.variant-btn').forEach(function(b) {
        b.style.borderColor = '';
        b.className = b.className.replace('border-accent', 'border-background/15');
      });
      btn.style.borderColor = '#001D45';
    });
  });

  var subCard = document.getElementById('lander-subscription-card');
  if (subCard) {
    subCard.addEventListener('click', function() {
      subCard.style.borderColor = '';
      subCard.style.background = '';
      subCard.className = subCard.className.replace('border-background/15', 'border-accent');
      var ctaRow = document.getElementById('lander-onetime-cta');
      if (ctaRow) ctaRow.style.display = 'none';
      buyBox.querySelectorAll('.variant-btn').forEach(function(b) {
        b.style.borderColor = '';
      });
    });
  }
});
</script>

{% schema %}
{
  "name": "Lander Buy Box",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "ELIGE TU PLAN"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Elige tu plan"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    }
  ],
  "presets": [
    {
      "name": "Lander Buy Box"
    }
  ]
}
{% endschema %}
