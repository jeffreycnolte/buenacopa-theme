<section class="w-full overflow-hidden">
  {%- liquid
    if section.settings.image
      assign banner_img = section.settings.image
      assign banner_alt = section.settings.alt_text | default: shop.name
    endif
  -%}
  {% if banner_img %}
    <img
      src="{{ banner_img | image_url: width: 1200 }}"
      srcset="{{ banner_img | image_url: width: 480 }} 480w,
             {{ banner_img | image_url: width: 768 }} 768w,
             {{ banner_img | image_url: width: 1200 }} 1200w,
             {{ banner_img | image_url: width: 1920 }} 1920w"
      sizes="100vw"
      alt="{{ banner_alt }}"
      class="w-full h-auto object-cover"
      width="1920"
      height="1081"
      loading="lazy"
      decoding="async"
    >
  {% else %}
    <img
      src="{{ 'banner-buenacopa.png' | asset_url }}"
      alt="{{ shop.name }}"
      class="w-full h-auto object-cover"
      width="1920"
      height="1081"
      loading="lazy"
      decoding="async"
    >
  {% endif %}
</section>

{% schema %}
{
  "name": "Brand Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner Image"
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Alt Text",
      "default": "BUENACOPA"
    }
  ],
  "presets": [
    {
      "name": "Brand Banner"
    }
  ]
}
{% endschema %}
