{%- assign current_product = product | default: section.settings.product -%}

<section class="section-padding overflow-hidden" id="reviews" style="background: #fff;">
  <div class="container-custom">
    <h2 class="font-display font-black text-center" style="font-size: clamp(1.5rem, 4vw, 2.25rem); color: #071D40; margin-bottom: 2rem;">
      {{ section.settings.heading | default: 'Reseñas de nuestros clientes' }}
    </h2>

    {%- comment -%}Judge.me Reviews — use carousel on homepage, full widget on product page{%- endcomment -%}
    {%- if request.page_type == 'product' -%}
      <div
        class="jdgm-widget jdgm-review-widget"
        data-id="{{ current_product.id }}"
        data-product-title="{{ current_product.title | escape }}"
      ></div>
    {%- else -%}
      {%- comment -%}Carousel widget works on any page — doesn't require product context{%- endcomment -%}
      <div class="jdgm-carousel-wrapper" data-auto-play="false" data-number-of-reviews="6" data-slides-to-show="3" data-slides-to-scroll="1">
        <div class="jdgm-carousel"></div>
      </div>

      {%- comment -%}Fallback: also try the all-reviews widget{%- endcomment -%}
      <div class="jdgm-widget jdgm-all-reviews-page" data-number-of-reviews="6" style="margin-top: 1rem;"></div>

      <script>
        document.addEventListener('DOMContentLoaded', function() {
          // Trigger Judge.me to initialize widgets
          if (typeof jdgm !== 'undefined') {
            if (jdgm.customizableWidgets) jdgm.customizableWidgets();
          }
          // Retry after a delay in case jdgm loads async
          setTimeout(function() {
            if (typeof jdgm !== 'undefined' && jdgm.customizableWidgets) {
              jdgm.customizableWidgets();
            }
          }, 3000);
        });
      </script>
    {%- endif -%}
  </div>

  <style>
    /* Judge.me overrides — match Buenacopa brand */
    #reviews .jdgm-widget {
      font-family: 'Inter', sans-serif !important;
    }

    /* Ensure widget is visible on all pages */
    #reviews .jdgm-review-widget,
    #reviews .jdgm-carousel-wrapper {
      display: block !important;
    }

    /* Stars — brand green */
    #reviews .jdgm-star {
      color: #00AB43 !important;
    }
    #reviews .jdgm-star.jdgm--on {
      color: #00AB43 !important;
    }

    /* Primary button — brand green */
    #reviews .jdgm-write-rev-link,
    #reviews .jdgm-submit-rev,
    #reviews a.jdgm-write-rev-link {
      background-color: #00AB43 !important;
      border-color: #00AB43 !important;
      color: #fff !important;
      border-radius: 12px !important;
      font-weight: 700 !important;
      font-family: 'Nunito', sans-serif !important;
      padding: 10px 24px !important;
    }
    #reviews .jdgm-write-rev-link:hover,
    #reviews .jdgm-submit-rev:hover {
      background-color: #009639 !important;
    }

    /* Review cards */
    #reviews .jdgm-rev {
      border-color: #e5e7eb !important;
      padding: 16px 0 !important;
    }

    /* Reviewer name */
    #reviews .jdgm-rev__author {
      font-weight: 700 !important;
      color: #071D40 !important;
    }

    /* Review body text */
    #reviews .jdgm-rev__body {
      color: #374151 !important;
      font-size: 14px !important;
      line-height: 1.6 !important;
    }

    /* Pagination */
    #reviews .jdgm-paginate a {
      color: #071D40 !important;
    }
    #reviews .jdgm-paginate a.jdgm--active {
      background-color: #00AB43 !important;
      color: #fff !important;
      border-radius: 8px !important;
    }

    /* Hide powered by badge */
    #reviews .jdgm-branding-footer {
      display: none !important;
    }

    /* Overall rating summary */
    #reviews .jdgm-rev-widg__summary-text {
      font-family: 'Nunito', sans-serif !important;
      font-weight: 800 !important;
      color: #071D40 !important;
    }
  </style>
</section>

{% schema %}
{
  "name": "Judge.me Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Reseñas de nuestros clientes"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product (optional — auto-detects on product pages)"
    }
  ],
  "presets": [
    {
      "name": "Judge.me Reviews"
    }
  ]
}
{% endschema %}
