<section id="como-usarlo" class="section-padding bg-background overflow-hidden">
  <div class="container-custom">
    <div class="text-center mb-16 md:mb-20">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-black text-foreground">
        {{ section.settings.heading | default: 'Tu ritual en 3 pasos' }}
      </h2>
    </div>

    <div class="max-w-5xl mx-auto relative">
      <!-- Vertical connector line -->
      <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-accent -translate-x-1/2"></div>

      <div class="space-y-16 md:space-y-24">
        {% for block in section.blocks %}
          {% if block.type == 'step' %}
            {% assign step_index = forloop.index %}
            {% assign image_on_right = true %}
            {% if step_index == 2 %}
              {% assign image_on_right = false %}
            {% endif %}

            <div class="relative" {{ block.shopify_attributes }}>
              <!-- Center dot -->
              <div class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-4 rounded-full border-2 border-accent bg-background z-10 items-center justify-center">
                <div class="w-1.5 h-1.5 rounded-full bg-accent"></div>
              </div>

              <div class="flex flex-col gap-8 items-center {% if image_on_right %}md:flex-row{% else %}md:flex-row-reverse{% endif %}">
                <!-- Text side -->
                <div class="flex-1 {% if image_on_right %}md:text-right md:pr-16{% else %}md:text-left md:pl-16{% endif %}">
                  <span class="text-6xl md:text-7xl font-display font-black text-accent/25 leading-none">
                    {{ block.settings.number | default: forloop.index | prepend: '0' }}
                  </span>
                  <h3 class="text-2xl md:text-3xl lg:text-4xl font-display font-bold text-foreground mt-2 mb-3">
                    {{ block.settings.title }}
                  </h3>
                  <p class="text-muted-foreground leading-relaxed max-w-md mx-auto md:mx-0">
                    {{ block.settings.description }}
                  </p>
                </div>

                <!-- Image -->
                <div class="flex-1 w-full">
                  <div class="aspect-[4/3] rounded-2xl overflow-hidden">
                    {% if block.settings.image %}
                      <img
                        src="{{ block.settings.image | image_url: width: 800 }}"
                        srcset="{{ block.settings.image | image_url: width: 400 }} 400w, {{ block.settings.image | image_url: width: 800 }} 800w, {{ block.settings.image | image_url: width: 1200 }} 1200w"
                        sizes="(max-width: 768px) 100vw, 50vw"
                        alt="{{ block.settings.title }}"
                        class="w-full h-full object-cover"
                        width="600"
                        height="450"
                        loading="lazy"
                        decoding="async"
                      >
                    {% else %}
                      {% assign step_images = 'step-01-celebra.png,step-02-capsulas.jpg,step-03-despierta.png' | split: ',' %}
                      {% assign img_index = forloop.index0 %}
                      {% if img_index < 3 %}
                        <img
                          src="{{ step_images[img_index] | asset_url }}"
                          alt="{{ block.settings.title }}"
                          class="w-full h-full object-cover"
                          width="600"
                          height="450"
                          loading="lazy"
                          decoding="async"
                        >
                      {% endif %}
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How It Works",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tu ritual en 3 pasos"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Step Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Step Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "01",
            "title": "Celebra tu noche",
            "description": "Disfruta de forma responsable. Buenacopa está diseñado para acompañar tus mejores noches."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "02",
            "title": "Toma tus 3 cápsulas antes de dormir",
            "description": "Con un vaso de agua, después de tu última copa. Buenacopa actúa mientras duermes."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "03",
            "title": "Despierta y conquista tu día",
            "description": "Sin cruda, sin náuseas, sin dolor de cabeza. Tu mañana es tuya."
          }
        }
      ]
    }
  ]
}
{% endschema %}
