{%- assign product = section.settings.product -%}
{%- if product == blank -%}
  {%- assign product = collections.all.products.first -%}
{%- endif -%}

{%- comment -%}
  Subscription data from Recharge selling plans
{%- endcomment -%}
{%- liquid
  assign has_subscription = false
  assign sub_variant = nil
  assign sub_plan = nil
  assign sub_price = 0
  assign sub_servings = 10

  for group in product.selling_plan_groups
    if group.selling_plans.size > 0
      assign has_subscription = true
      assign sub_plan = group.selling_plans[0]
      for variant in product.variants
        for allocation in variant.selling_plan_allocations
          if allocation.selling_plan.id == sub_plan.id
            assign sub_variant = variant
            assign sub_price = allocation.price
            break
          endif
        endfor
        if sub_variant
          break
        endif
      endfor
      break
    endif
  endfor

  if sub_price > 0 and sub_servings > 0
    assign sub_per_serving = sub_price | divided_by: sub_servings
  else
    assign sub_per_serving = 0
  endif

  assign cheapest_price = product.price_min
-%}

<section id="comprar" class="bg-white overflow-hidden">
  <div class="py-6 md:py-16 lg:py-28 px-4 sm:px-6 md:px-8">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-6 lg:gap-14 items-start">

        <!-- LEFT: Product Images + Thumbnails -->
        <div class="space-y-3">
          <div class="rounded-2xl lg:rounded-3xl overflow-hidden aspect-square">
            <img
              id="main-product-image"
              src="{{ product.featured_image | image_url: width: 1200 }}"
              srcset="{{ product.featured_image | image_url: width: 400 }} 400w, {{ product.featured_image | image_url: width: 800 }} 800w, {{ product.featured_image | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 768px) 100vw, 50vw"
              alt="{{ product.featured_image.alt | default: product.title }}"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
              width="600"
              height="600"
            >
          </div>
          <div class="flex gap-1.5 sm:gap-3 overflow-x-auto scrollbar-hide" id="product-thumbnails">
            {%- for image in product.images limit: 5 -%}
              <button
                onclick="ProductForm.selectImage('{{ image | image_url: width: 1200 }}', this)"
                aria-label="{{ 'sections.product.view_image' | t: index: forloop.index }}"
                class="product-thumbnail rounded-lg sm:rounded-xl overflow-hidden border-2 transition-all {% if forloop.first %}border-accent{% else %}border-background/10 hover:border-background/25{% endif %}"
              >
                <img src="{{ image | image_url: width: 160 }}" alt="{{ 'sections.product.image_alt' | t: index: forloop.index }}" class="w-full h-full object-cover" loading="lazy" decoding="async" width="80" height="80">
              </button>
            {%- endfor -%}
          </div>
        </div>

        <!-- RIGHT: Unified Purchase Flow -->
        <div class="space-y-4 pb-20 lg:pb-0" id="product-form-container" data-product-id="{{ product.id }}">
          <h2 class="sr-only">{{ product.title }}</h2>

          <!-- Shipping badge -->
          <div class="flex items-center gap-2 text-background/50">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span style="font-size:12px" class="font-medium">Envíos a todo México</span>
          </div>

          {%- comment -%}Format prices manually to avoid locale spacing{%- endcomment -%}
          {%- assign sub_price_whole = sub_price | divided_by: 100 -%}
          {%- assign sub_price_cents = sub_price | modulo: 100 -%}
          {%- assign sub_per_whole = sub_per_serving | divided_by: 100 -%}

          <!-- ═══ SUBSCRIPTION CARD ═══ -->
          {% if has_subscription and sub_variant %}
            <div
              id="subscription-card"
              class="relative rounded-xl border-2 border-accent cursor-pointer transition-all"
              style="background: linear-gradient(180deg, rgba(0,171,67,0.06) 0%, rgba(0,171,67,0.02) 100%); padding: 32px 16px 16px;"
              onclick="ProductForm.selectSubscription({{ sub_variant.id }}, {{ sub_plan.id }})"
              data-variant-id="{{ sub_variant.id }}"
              data-selling-plan-id="{{ sub_plan.id }}"
              data-price="{{ sub_price }}"
            >
              <span class="absolute left-3" style="top:-11px; font-size:11px; letter-spacing:0.05em; display:inline-flex; align-items:center; gap:5px; background:#00AB43; color:#fff; font-weight:700; text-transform:uppercase; padding:3px 10px; border-radius:999px;">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                MEJOR VALOR
              </span>

              <div class="flex items-baseline justify-between">
                <p class="font-bold text-background" style="font-size:14px">Suscripción ({{ sub_servings }} sobres)</p>
                <p class="font-display font-black text-background" style="white-space:nowrap"><span style="font-size:22px">${{ sub_price_whole }}</span>{%- if sub_price_cents > 0 -%}<span style="font-size:14px">.{{ sub_price_cents }}</span>{%- endif -%}<span style="font-size:11px; color:rgba(7,29,64,0.4); font-weight:600; margin-left:2px">/mes</span></p>
              </div>

              <div style="margin-top:10px; display:flex; flex-direction:column; gap:4px">
                <div style="display:flex; align-items:center; gap:7px">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span style="font-size:12px; color:rgba(7,29,64,0.65)"><strong>${{ sub_per_whole }} por toma</strong></span>
                </div>
                <div style="display:flex; align-items:center; gap:7px">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span style="font-size:12px; color:rgba(7,29,64,0.65)"><strong>Ahorra 40%</strong></span>
                </div>
                <div style="display:flex; align-items:center; gap:7px">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span style="font-size:12px; color:rgba(7,29,64,0.65)">Nunca te quedes sin producto</span>
                </div>
                <div style="display:flex; align-items:center; gap:7px">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span style="font-size:12px; color:rgba(7,29,64,0.65)">Cancela cuando quieras</span>
                </div>
              </div>

              <button
                onclick="event.stopPropagation(); ProductForm.selectSubscription({{ sub_variant.id }}, {{ sub_plan.id }}); ProductForm.addToCart();"
                class="w-full btn-cta flex items-center justify-center gap-2"
                style="margin-top:14px; font-size:14px; padding:10px 0"
              >
                Suscribirme ahora
                <span class="inline-flex">{% render 'icon-arrow-right', size: 16 %}</span>
              </button>
            </div>
          {% endif %}

          <!-- ═══ ONE-TIME PURCHASE ═══ -->
          <div>
            <div class="flex items-center gap-3" style="margin-top:4px">
              <p class="font-bold text-background shrink-0" style="font-size:14px">Compra única</p>
              <div class="flex-1 h-px bg-background/10"></div>
            </div>

            <div class="space-y-2" style="margin-top:8px" id="variant-selector">
              {%- for variant in product.variants -%}
                {%- liquid
                  assign variant_title_lower = variant.title | downcase
                  assign is_sub_only = false
                  if variant_title_lower contains 'suscripción' or variant_title_lower contains 'suscripcion' or variant_title_lower contains 'subscription'
                    assign is_sub_only = true
                  endif

                  assign servings = 10
                  if variant_title_lower contains '20'
                    assign servings = 20
                  elsif variant_title_lower contains '30'
                    assign servings = 30
                  elsif variant_title_lower contains '5 '
                    assign servings = 5
                  endif

                  if variant.price > 0 and servings > 0
                    assign per_serving = variant.price | divided_by: servings
                  else
                    assign per_serving = 0
                  endif
                -%}

                {%- unless is_sub_only -%}
                  <button
                    type="button"
                    onclick="ProductForm.selectOneTime({{ variant.id }}, this)"
                    aria-label="{{ 'sections.product.select_variant' | t: title: variant.title }}"
                    data-variant-id="{{ variant.id }}"
                    data-variant-price="{{ variant.price }}"
                    data-variant-available="{{ variant.available }}"
                    class="variant-btn w-full flex items-center justify-between rounded-xl border-2 transition-all duration-200 text-left border-background/15 bg-background/5 hover:border-background/25 {% unless variant.available %}opacity-50 cursor-not-allowed{% endunless %}"
                    style="padding:12px 14px"
                    {% unless variant.available %}disabled{% endunless %}
                  >
                    <span class="font-bold text-background" style="font-size:13px">{{ variant.title }}</span>
                    <div class="flex items-baseline" style="gap:6px">
                      {%- assign v_whole = variant.price | divided_by: 100 -%}
                    {%- assign v_cents = variant.price | modulo: 100 -%}
                    {%- capture v_formatted -%}{%- if v_whole >= 1000 -%}{{ v_whole | divided_by: 1000 }},{{ v_whole | modulo: 1000 | prepend: '000' | slice: -3, 3 }}{%- else -%}{{ v_whole }}{%- endif -%}{%- endcapture -%}
                    <span class="font-display font-black text-background" style="font-size:16px">${{ v_formatted }}{%- if v_cents > 0 -%}.{{ v_cents }}{%- endif -%}</span>
                      {% if per_serving > 0 %}
                        {%- assign ps_whole = per_serving | divided_by: 100 -%}
                        {%- assign ps_cents = per_serving | modulo: 100 -%}
                        <span class="text-background/40" style="font-size:11px">(${{ ps_whole }}{% if ps_cents > 0 %}.{{ ps_cents }}{% endif %} por toma)</span>
                      {% endif %}
                    </div>
                  </button>
                {%- endunless -%}
              {%- endfor -%}
            </div>

            <!-- One-time CTA (shown when a one-time variant is selected) -->
            <button
              id="add-to-cart-btn"
              onclick="ProductForm.addToCart()"
              class="w-full mt-3 flex items-center justify-center gap-2.5 bg-[#004AB2] text-white font-bold text-base py-3.5 rounded-xl hover:bg-[#003d94] transition-colors disabled:opacity-50"
              style="display: none;"
            >
              Finalizar compra
            </button>
          </div>

          <!-- Trust Badges -->
          <div class="flex items-center justify-center text-background/50" style="gap:12px; padding:8px 0">
            <div class="flex items-center whitespace-nowrap" style="gap:4px; font-size:10px; font-weight:500">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="shrink-0"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              {{ 'general.security.ssl_badge' | t }}
            </div>
            <span class="text-background/20">|</span>
            <div class="flex items-center whitespace-nowrap" style="gap:4px; font-size:10px; font-weight:500">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="shrink-0"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              {{ 'general.security.free_shipping_badge' | t }}
            </div>
            <span class="text-background/20">|</span>
            <div class="flex items-center whitespace-nowrap" style="gap:4px; font-size:10px; font-weight:500">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="shrink-0"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {{ 'general.security.guarantee_badge' | t }}
            </div>
          </div>

          <!-- Dropdowns -->
          <div>
            {% for block in section.blocks %}
              {% if block.type == 'dropdown' %}
                <div class="dropdown-section">
                  <button onclick="ProductForm.toggleDropdown(this)" aria-expanded="false" class="w-full flex items-center justify-between py-4 border-t border-background/10 text-left">
                    <span class="font-bold text-background text-sm">{{ block.settings.title }}</span>
                    <span class="text-background/50 transition-transform duration-200 dropdown-chevron">{% render 'icon-chevron-down', size: 16 %}</span>
                  </button>
                  <div class="dropdown-content">
                    <div>
                      <div class="pb-4 text-background/60 text-sm leading-relaxed">
                        {{ block.settings.content }}
                      </div>
                    </div>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<!-- Mobile Sticky CTA -->
<div id="mobile-sticky-cta" class="fixed bottom-0 left-0 right-0 z-50 lg:hidden bg-accent px-4 pt-2 pb-3 shadow-[0_-4px_20px_rgba(0,0,0,0.15)]">
  <button
    onclick="ProductForm.addToCart()"
    class="w-full flex items-center justify-center gap-2 text-white font-bold text-base py-3 rounded-xl disabled:opacity-50"
  >
    <span class="inline-flex">{% render 'icon-cart', size: 20 %}</span>
    <span id="mobile-cta-text">Suscribirme – {% if sub_price > 0 %}{%- render 'price', amount: sub_price -%}/mes{% else %}{%- render 'price', amount: product.selected_or_first_available_variant.price -%}{% endif %}</span>
  </button>
</div>

<!-- Product JSON-LD -->
{% if product %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "image": "https:{{ product.featured_image | image_url: width: 1200 }}",
  "description": {{ product.description | strip_html | truncate: 5000 | json }},
  "brand": {
    "@type": "Brand",
    "name": {{ shop.name | json }}
  },
  "offers": [
    {% for variant in product.variants %}
    {
      "@type": "Offer",
      "name": {{ variant.title | json }},
      "price": "{{ variant.price | money_without_currency | strip }}",
      "priceCurrency": "{{ cart.currency.iso_code }}",
      "availability": "{% if variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "url": "{{ shop.url }}{{ product.url }}?variant={{ variant.id }}"
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
  {%- assign rating_value = product.metafields.reviews.rating.value | default: product.metafields.judgeme.average -%}
  {%- assign review_count = product.metafields.reviews.rating_count.value | default: product.metafields.judgeme.review_count -%}
  {%- if rating_value != blank and review_count != blank -%}
  ,"aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": {{ rating_value | json }},
    "bestRating": "5",
    "reviewCount": {{ review_count | json }}
  }
  {%- endif -%}
}
</script>
{% endif %}

{% schema %}
{
  "name": "Product Showcase",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "image_picker",
      "id": "product_logo",
      "label": "Product Logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Product Tagline",
      "default": "Bienestar Post-Fiesta"
    },
    {
      "type": "text",
      "id": "review_label",
      "label": "Review Label",
      "default": "10,000+ mañanas sin cruda"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review Count (for Google Schema)",
      "default": "150"
    },
    {
      "type": "url",
      "id": "amazon_url",
      "label": "Amazon URL"
    },
    {
      "type": "url",
      "id": "mercadolibre_url",
      "label": "Mercado Libre URL"
    }
  ],
  "blocks": [
    {
      "type": "dropdown",
      "name": "Info Dropdown",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Showcase",
      "blocks": [
        {
          "type": "dropdown",
          "settings": {
            "title": "Modo de uso",
            "content": "<ul><li>Toma 1 dosis (3 cápsulas) después de tu última copa</li><li>Hidrátate con un vaso grande de agua</li><li>Descansa y despierta listo para disfrutar tu día</li></ul>"
          }
        },
        {
          "type": "dropdown",
          "settings": {
            "title": "Ingredientes",
            "content": "<ul><li><strong>DHM:</strong> Acelera el metabolismo del alcohol y equilibra tus neurotransmisores</li><li><strong>L-Cisteína:</strong> Neutraliza las toxinas del alcohol y protege tu hígado</li><li><strong>Vitamina C:</strong> Antioxidante que combate el estrés en tus células</li><li><strong>Cúrcuma:</strong> Ayuda a disminuir la inflamación</li></ul>"
          }
        },
        {
          "type": "dropdown",
          "settings": {
            "title": "Información de envío",
            "content": "<p>Para que estés preparado cuando llegue la próxima celebración</p><p><strong>Envío Express (2-3 días):</strong> GRATIS por tiempo limitado</p><p><strong>Procesamiento el mismo día.</strong> Realiza tu pedido antes de la 1:00 p.m. (hora CDMX) y lo enviamos el mismo día.</p><p><em>Aplica únicamente en días hábiles.</em></p><p><strong>BUENACOPA. BUENOS DÍAS.</strong></p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
