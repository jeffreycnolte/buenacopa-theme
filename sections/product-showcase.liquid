{%- assign product = section.settings.product -%}
{%- if product == blank -%}
  {%- assign product = collections.all.products.first -%}
{%- endif -%}

<section id="comprar" class="bg-white overflow-hidden">
  <div class="py-8 md:py-16 lg:py-28 px-4 sm:px-6 md:px-8">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-6 lg:gap-14 items-start">

        <!-- Product Images + Thumbnails -->
        <div class="space-y-3">
          <div class="rounded-2xl lg:rounded-3xl overflow-hidden aspect-square">
            <img
              id="main-product-image"
              src="{{ product.featured_image | image_url: width: 1200 }}"
              srcset="{{ product.featured_image | image_url: width: 400 }} 400w, {{ product.featured_image | image_url: width: 800 }} 800w, {{ product.featured_image | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 768px) 100vw, 50vw"
              alt="{{ product.featured_image.alt | default: product.title }}"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
              width="600"
              height="600"
            >
          </div>
          <div class="flex gap-1.5 sm:gap-3 overflow-x-auto scrollbar-hide" id="product-thumbnails">
            {%- for image in product.images limit: 5 -%}
              <button
                onclick="ProductForm.selectImage('{{ image | image_url: width: 1200 }}', this)"
                aria-label="{{ 'sections.product.view_image' | t: index: forloop.index }}"
                class="product-thumbnail rounded-lg sm:rounded-xl overflow-hidden border-2 transition-all {% if forloop.first %}border-accent{% else %}border-background/10 hover:border-background/25{% endif %}"
              >
                <img src="{{ image | image_url: width: 160 }}" alt="{{ 'sections.product.image_alt' | t: index: forloop.index }}" class="w-full h-full object-cover" loading="lazy" decoding="async" width="80" height="80">
              </button>
            {%- endfor -%}
          </div>
        </div>

        <!-- Product Info -->
        <div class="space-y-4 pb-28 lg:pb-0" id="product-form-container" data-product-id="{{ product.id }}">
          <h2 class="sr-only">{{ product.title }}</h2>

          <!-- Logo + Tagline -->
          <div>
            {% if section.settings.product_logo %}
              <img src="{{ section.settings.product_logo | image_url: width: 320 }}" alt="{{ product.title }}" class="h-10 md:h-12 w-auto" width="160" height="48" loading="lazy" decoding="async">
            {% else %}
              <img src="{{ 'logo-azul-oscuro.png' | asset_url }}" alt="{{ product.title }}" class="h-10 md:h-12 w-auto" width="160" height="48" loading="lazy" decoding="async">
            {% endif %}
            {% if section.settings.tagline != blank %}
              <p class="text-accent-contrast font-display font-bold text-lg mt-2">{{ section.settings.tagline }}</p>
            {% endif %}
          </div>

          <!-- Rating -->
          <div class="flex items-center gap-3">
            <div class="flex gap-0.5">
              {% for s in (1..5) %}
                {% render 'icon-star', size: 20, fill: '#facc15', stroke: '#facc15' %}
              {% endfor %}
            </div>
            <span class="text-background/50 text-sm font-medium">{{ section.settings.review_label | default: '10,000+ mañanas sin cruda' }}</span>
          </div>

          <!-- Description — always from the product itself -->
          {% if product.description != blank %}
            <div class="text-background/60 leading-relaxed text-sm product-description">
              {{ product.description }}
            </div>
          {% endif %}

          <!-- Benefits -->
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-3">
            <div class="flex items-center gap-2">
              <span class="text-accent shrink-0">{% render 'icon-leaf', size: 20 %}</span>
              <span class="text-background/70 text-sm font-medium">{{ 'sections.product.benefit_natural' | t }}</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-accent shrink-0">{% render 'icon-coffee', size: 20 %}</span>
              <span class="text-background/70 text-sm font-medium">{{ 'sections.product.benefit_caffeine' | t }}</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-accent shrink-0">{% render 'icon-truck', size: 20 %}</span>
              <span class="text-background/70 text-sm font-medium">{{ 'sections.product.benefit_shipping' | t }}</span>
            </div>
          </div>

          {%- comment -%}
            Buy Box: Subscription first, then one-time variants.
            Recharge selling plans accessed via product.selling_plan_groups.
          {%- endcomment -%}

          {%- liquid
            assign has_subscription = false
            assign sub_variant = nil
            assign sub_plan = nil
            assign sub_price = 0
            assign sub_servings = 10

            for group in product.selling_plan_groups
              if group.selling_plans.size > 0
                assign has_subscription = true
                assign sub_plan = group.selling_plans[0]
                for variant in product.variants
                  for allocation in variant.selling_plan_allocations
                    if allocation.selling_plan.id == sub_plan.id
                      assign sub_variant = variant
                      assign sub_price = allocation.price
                      break
                    endif
                  endfor
                  if sub_variant
                    break
                  endif
                endfor
                break
              endif
            endfor

            if sub_price > 0 and sub_servings > 0
              assign sub_per_serving = sub_price | divided_by: sub_servings
            else
              assign sub_per_serving = 0
            endif
          -%}

          <!-- Subscription Card -->
          {% if has_subscription and sub_variant %}
            <div
              id="subscription-card"
              class="relative rounded-2xl border-2 border-accent bg-accent/5 p-5 cursor-pointer transition-all selected"
              onclick="ProductForm.selectSubscription({{ sub_variant.id }}, {{ sub_plan.id }})"
              data-variant-id="{{ sub_variant.id }}"
              data-selling-plan-id="{{ sub_plan.id }}"
              data-price="{{ sub_price }}"
            >
              <span class="absolute -top-3 left-4 inline-flex items-center gap-1.5 bg-accent text-white text-xs font-bold uppercase tracking-wide px-3 py-1 rounded-full">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                MEJOR VALOR
              </span>

              <div class="flex items-start justify-between mt-2">
                <div>
                  <p class="font-bold text-background text-base">Suscripción ({{ sub_servings }} sobres)</p>
                </div>
                <div class="text-right">
                  <p class="font-display font-black text-xl text-background">{%- render 'price', amount: sub_price -%}<span class="text-sm font-semibold text-background/50">/mes</span></p>
                </div>
              </div>

              <div class="mt-3 space-y-1.5">
                <div class="flex items-center gap-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-sm text-background/70"><strong>${{ sub_per_serving | divided_by: 100 }} por toma</strong></span>
                </div>
                <div class="flex items-center gap-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-sm text-background/70"><strong>Ahorra 40%</strong></span>
                </div>
                <div class="flex items-center gap-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-sm text-background/70">Nunca te quedes sin producto</span>
                </div>
                <div class="flex items-center gap-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-sm text-background/70">Cancela cuando quieras</span>
                </div>
              </div>

              <button
                onclick="event.stopPropagation(); ProductForm.selectSubscription({{ sub_variant.id }}, {{ sub_plan.id }}); ProductForm.addToCart();"
                class="w-full mt-4 btn-cta text-base py-3 flex items-center justify-center gap-2"
              >
                Suscribirme ahora
                <span class="inline-flex">{% render 'icon-arrow-right', size: 18 %}</span>
              </button>
            </div>
          {% endif %}

          <!-- One-Time Purchase -->
          <div class="pt-2">
            <div class="flex items-center gap-3">
              <p class="font-bold text-background text-base shrink-0">Compra única</p>
              <div class="flex-1 h-px bg-background/10"></div>
            </div>

            <div class="space-y-2 mt-3" id="variant-selector">
              {%- for variant in product.variants -%}
                {%- comment -%}Skip subscription-only variants if they match the sub variant{%- endcomment -%}
                {%- liquid
                  assign variant_title_lower = variant.title | downcase
                  assign is_sub_only = false
                  if variant_title_lower contains 'suscripción' or variant_title_lower contains 'suscripcion' or variant_title_lower contains 'subscription'
                    assign is_sub_only = true
                  endif

                  assign servings = 10
                  if variant_title_lower contains '20'
                    assign servings = 20
                  elsif variant_title_lower contains '30'
                    assign servings = 30
                  elsif variant_title_lower contains '5 '
                    assign servings = 5
                  endif

                  if variant.price > 0 and servings > 0
                    assign per_serving = variant.price | divided_by: servings
                  else
                    assign per_serving = 0
                  endif
                -%}

                {%- unless is_sub_only -%}
                  <button
                    type="button"
                    onclick="ProductForm.selectOneTime({{ variant.id }}, this)"
                    aria-label="{{ 'sections.product.select_variant' | t: title: variant.title }}"
                    data-variant-id="{{ variant.id }}"
                    data-variant-price="{{ variant.price }}"
                    data-variant-available="{{ variant.available }}"
                    class="variant-btn w-full flex items-center justify-between px-4 py-3.5 rounded-xl border-2 transition-all duration-200 text-left border-background/15 bg-background/5 hover:border-background/25 {% unless variant.available %}opacity-50 cursor-not-allowed{% endunless %}"
                    {% unless variant.available %}disabled{% endunless %}
                  >
                    <span class="font-bold text-background text-sm">{{ variant.title }}</span>
                    <div class="flex items-baseline gap-2">
                      <span class="font-display font-black text-lg text-background">{%- render 'price', amount: variant.price -%}</span>
                      {% if per_serving > 0 %}
                        <span class="text-background/40 text-xs">({%- render 'price', amount: per_serving -%} por toma)</span>
                      {% endif %}
                    </div>
                  </button>
                {%- endunless -%}
              {%- endfor -%}
            </div>

            <!-- Single CTA for one-time -->
            <button
              id="add-to-cart-btn"
              onclick="ProductForm.addToCart()"
              class="w-full mt-3 flex items-center justify-center gap-2.5 bg-[#004AB2] text-white font-bold text-base py-3.5 rounded-xl hover:bg-[#003d94] transition-colors disabled:opacity-50"
              style="display: none;"
            >
              Finalizar compra
            </button>
          </div>

          <!-- Trust Badges -->
          <div class="flex items-center justify-center gap-4 py-2 text-background/50">
            <div class="flex items-center gap-1.5 text-xs font-medium">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              {{ 'general.security.ssl_badge' | t }}
            </div>
            <div class="flex items-center gap-1.5 text-xs font-medium">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {{ 'general.security.guarantee_badge' | t }}
            </div>
            <div class="flex items-center gap-1.5 text-xs font-medium">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              {{ 'general.security.free_shipping_badge' | t }}
            </div>
          </div>

          <!-- Marketplace buttons — single responsive set, no duplicate mobile PNGs -->
          <div class="grid grid-cols-2 gap-3">
            <a href="{{ section.settings.amazon_url | default: 'https://www.amazon.com.mx/stores/page/FDB18C6D-10B7-43A2-AA75-D935DEF10C38?channel=BOTONSITIOWEB' }}" target="_blank" rel="noopener noreferrer" class="block hover:opacity-90 transition-opacity">
              <img src="{{ 'boton-amazon.png' | asset_url }}" alt="{{ 'sections.product.buy_amazon_alt' | t }}" class="w-full h-auto rounded-lg lg:rounded-xl" loading="lazy" decoding="async" width="300" height="82">
            </a>
            <a href="{{ section.settings.mercadolibre_url | default: 'https://www.mercadolibre.com.mx/tienda/buenacopa' }}" target="_blank" rel="noopener noreferrer" class="block hover:opacity-90 transition-opacity">
              <img src="{{ 'boton-mercadolibre.png' | asset_url }}" alt="{{ 'sections.product.buy_ml_alt' | t }}" class="w-full h-auto rounded-lg lg:rounded-xl" loading="lazy" decoding="async" width="300" height="82">
            </a>
          </div>

          <!-- Dropdowns -->
          <div>
            {% for block in section.blocks %}
              {% if block.type == 'dropdown' %}
                <div class="dropdown-section">
                  <button onclick="ProductForm.toggleDropdown(this)" aria-expanded="false" class="w-full flex items-center justify-between py-4 border-t border-background/10 text-left">
                    <span class="font-bold text-background text-sm">{{ block.settings.title }}</span>
                    <span class="text-background/50 transition-transform duration-200 dropdown-chevron">{% render 'icon-chevron-down', size: 16 %}</span>
                  </button>
                  <div class="dropdown-content">
                    <div>
                      <div class="pb-4 text-background/60 text-sm leading-relaxed">
                        {{ block.settings.content }}
                      </div>
                    </div>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<!-- Mobile Sticky CTA -->
<div id="mobile-sticky-cta" class="fixed bottom-0 left-0 right-0 z-50 lg:hidden bg-accent px-4 pt-2 pb-3 shadow-[0_-4px_20px_rgba(0,0,0,0.15)]">
  <button
    onclick="ProductForm.addToCart()"
    class="w-full flex items-center justify-center gap-2 text-white font-bold text-base py-3 rounded-xl disabled:opacity-50"
  >
    <span class="inline-flex">{% render 'icon-cart', size: 20 %}</span>
    <span id="mobile-cta-text">Suscribirme – {% if sub_price > 0 %}{%- render 'price', amount: sub_price -%}/mes{% else %}{%- render 'price', amount: product.selected_or_first_available_variant.price -%}{% endif %}</span>
  </button>
</div>

<!-- Product JSON-LD -->
{% if product %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "image": "https:{{ product.featured_image | image_url: width: 1200 }}",
  "description": {{ product.description | strip_html | truncate: 5000 | json }},
  "brand": {
    "@type": "Brand",
    "name": {{ shop.name | json }}
  },
  "offers": [
    {% for variant in product.variants %}
    {
      "@type": "Offer",
      "name": {{ variant.title | json }},
      "price": "{{ variant.price | money_without_currency | strip }}",
      "priceCurrency": "{{ cart.currency.iso_code }}",
      "availability": "{% if variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "url": "{{ shop.url }}{{ product.url }}?variant={{ variant.id }}"
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
  {%- assign rating_value = product.metafields.reviews.rating.value | default: product.metafields.judgeme.average -%}
  {%- assign review_count = product.metafields.reviews.rating_count.value | default: product.metafields.judgeme.review_count -%}
  {%- if rating_value != blank and review_count != blank -%}
  ,"aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": {{ rating_value | json }},
    "bestRating": "5",
    "reviewCount": {{ review_count | json }}
  }
  {%- endif -%}
}
</script>
{% endif %}

{% schema %}
{
  "name": "Product Showcase",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "image_picker",
      "id": "product_logo",
      "label": "Product Logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Product Tagline",
      "default": "Bienestar Post-Fiesta"
    },
    {
      "type": "text",
      "id": "review_label",
      "label": "Review Label",
      "default": "10,000+ mañanas sin cruda"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review Count (for Google Schema)",
      "default": "150"
    },
    {
      "type": "url",
      "id": "amazon_url",
      "label": "Amazon URL"
    },
    {
      "type": "url",
      "id": "mercadolibre_url",
      "label": "Mercado Libre URL"
    }
  ],
  "blocks": [
    {
      "type": "dropdown",
      "name": "Info Dropdown",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Showcase",
      "blocks": [
        {
          "type": "dropdown",
          "settings": {
            "title": "Modo de uso",
            "content": "<ul><li>Toma 1 dosis (3 cápsulas) después de tu última copa</li><li>Hidrátate con un vaso grande de agua</li><li>Descansa y despierta listo para disfrutar tu día</li></ul>"
          }
        },
        {
          "type": "dropdown",
          "settings": {
            "title": "Ingredientes",
            "content": "<ul><li><strong>DHM:</strong> Acelera el metabolismo del alcohol y equilibra tus neurotransmisores</li><li><strong>L-Cisteína:</strong> Neutraliza las toxinas del alcohol y protege tu hígado</li><li><strong>Vitamina C:</strong> Antioxidante que combate el estrés en tus células</li><li><strong>Cúrcuma:</strong> Ayuda a disminuir la inflamación</li></ul>"
          }
        },
        {
          "type": "dropdown",
          "settings": {
            "title": "Información de envío",
            "content": "<p>Para que estés preparado cuando llegue la próxima celebración</p><p><strong>Envío Express (2-3 días):</strong> GRATIS por tiempo limitado</p><p><strong>Procesamiento el mismo día.</strong> Realiza tu pedido antes de la 1:00 p.m. (hora CDMX) y lo enviamos el mismo día.</p><p><em>Aplica únicamente en días hábiles.</em></p><p><strong>BUENACOPA. BUENOS DÍAS.</strong></p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}