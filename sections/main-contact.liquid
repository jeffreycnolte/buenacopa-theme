<section class="section-padding bg-background overflow-hidden">
  <div class="container-custom">
    <div class="max-w-2xl mx-auto">

      <!-- Heading -->
      <div class="text-center mb-10 md:mb-14">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-display font-black text-foreground mb-4">
          {{ section.settings.heading | default: 'Contáctanos' }}
        </h1>
        <p class="text-base md:text-lg text-foreground/70 font-sans leading-relaxed max-w-lg mx-auto">
          {{ section.settings.intro_text | default: '¿Tienes dudas sobre Buenacopa? Escríbenos y te respondemos lo antes posible.' }}
        </p>
      </div>

      <!-- Contact Form -->
      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <div class="bg-accent/20 border border-accent rounded-2xl p-6 text-center mb-8">
            <p class="text-foreground font-bold font-display text-lg">
              {{ section.settings.success_message | default: '¡Mensaje enviado! Te responderemos pronto.' }}
            </p>
          </div>
        {% endif %}

        {% if form.errors %}
          <div class="bg-red-500/20 border border-red-500 rounded-2xl p-6 mb-8">
            <p class="text-foreground font-bold mb-2">Por favor corrige los siguientes errores:</p>
            <ul class="list-disc list-inside text-foreground/80 text-sm">
              {% for field in form.errors %}
                <li>{{ form.errors.translated_fields[field] }} — {{ form.errors.messages[field] }}</li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}

        <div class="space-y-5">
          <!-- Name -->
          <div>
            <label for="contact-name" class="block text-foreground font-bold text-sm mb-2 font-sans">
              {{ section.settings.label_name | default: 'Nombre' }} <span class="text-accent">*</span>
            </label>
            <input
              type="text"
              id="contact-name"
              name="contact[{{ 'contact.form.name' | t }}]"
              required
              autocomplete="name"
              placeholder="{{ section.settings.placeholder_name | default: 'Tu nombre completo' }}"
              class="w-full px-4 py-3 rounded-xl bg-background border border-border/30 text-foreground placeholder-foreground/40 font-sans focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent transition-colors"
            >
          </div>

          <!-- Email -->
          <div>
            <label for="contact-email" class="block text-foreground font-bold text-sm mb-2 font-sans">
              {{ section.settings.label_email | default: 'Correo electrónico' }} <span class="text-accent">*</span>
            </label>
            <input
              type="email"
              id="contact-email"
              name="contact[email]"
              required
              autocomplete="email"
              placeholder="{{ section.settings.placeholder_email | default: 'tu@correo.com' }}"
              class="w-full px-4 py-3 rounded-xl bg-background border border-border/30 text-foreground placeholder-foreground/40 font-sans focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent transition-colors"
            >
          </div>

          <!-- Phone (optional) -->
          <div>
            <label for="contact-phone" class="block text-foreground font-bold text-sm mb-2 font-sans">
              {{ section.settings.label_phone | default: 'Teléfono' }} <span class="text-foreground/40 font-normal">(opcional)</span>
            </label>
            <input
              type="tel"
              id="contact-phone"
              name="contact[{{ 'contact.form.phone' | t }}]"
              autocomplete="tel"
              placeholder="{{ section.settings.placeholder_phone | default: '+52 55 1234 5678' }}"
              class="w-full px-4 py-3 rounded-xl bg-background border border-border/30 text-foreground placeholder-foreground/40 font-sans focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent transition-colors"
            >
          </div>

          <!-- Message -->
          <div>
            <label for="contact-message" class="block text-foreground font-bold text-sm mb-2 font-sans">
              {{ section.settings.label_message | default: 'Mensaje' }} <span class="text-accent">*</span>
            </label>
            <textarea
              id="contact-message"
              name="contact[body]"
              required
              rows="5"
              placeholder="{{ section.settings.placeholder_message | default: '¿En qué podemos ayudarte?' }}"
              class="w-full px-4 py-3 rounded-xl bg-background border border-border/30 text-foreground placeholder-foreground/40 font-sans focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent transition-colors resize-y"
            ></textarea>
          </div>

          <!-- Submit -->
          <div class="pt-2">
            <button type="submit" class="btn-cta w-full sm:w-auto inline-flex items-center justify-center gap-2 text-base">
              {{ section.settings.submit_text | default: 'Enviar mensaje' }}
              <span class="inline-flex">{% render 'icon-arrow-right', size: 20 %}</span>
            </button>
          </div>
        </div>
      {% endform %}

      <!-- WhatsApp + Social -->
      <div class="mt-12 md:mt-16 pt-10 border-t border-border/20">
        <div class="text-center space-y-6">

          <!-- WhatsApp CTA -->
          {% if section.settings.whatsapp_url != blank %}
            <div>
              <p class="text-foreground/70 font-sans text-sm mb-3">
                {{ section.settings.whatsapp_label | default: '¿Prefieres escribirnos directo?' }}
              </p>
              <a
                href="{{ section.settings.whatsapp_url }}"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 bg-[#25D366] hover:bg-[#20bd5a] text-white font-bold rounded-full transition-colors text-sm"
              >
                <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                {{ section.settings.whatsapp_text | default: 'Escríbenos por WhatsApp' }}
              </a>
            </div>
          {% endif %}

          <!-- Social Links -->
          {% if settings.social_instagram_link != blank or settings.social_facebook_link != blank %}
            <div>
              <p class="text-foreground/70 font-sans text-sm mb-3">
                {{ section.settings.social_label | default: 'Síguenos en redes' }}
              </p>
              <div class="flex items-center justify-center gap-4">
                {% if settings.social_instagram_link != blank %}
                  <a
                    href="{{ settings.social_instagram_link }}"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Instagram"
                    class="w-11 h-11 flex items-center justify-center rounded-full border border-border/30 text-foreground/70 hover:text-accent hover:border-accent transition-colors"
                  >
                    <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                    </svg>
                  </a>
                {% endif %}
                {% if settings.social_facebook_link != blank %}
                  <a
                    href="{{ settings.social_facebook_link }}"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Facebook"
                    class="w-11 h-11 flex items-center justify-center rounded-full border border-border/30 text-foreground/70 hover:text-accent hover:border-accent transition-colors"
                  >
                    <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                    </svg>
                  </a>
                {% endif %}
              </div>
            </div>
          {% endif %}

        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Page",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contáctanos"
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Intro Text",
      "default": "¿Tienes dudas sobre Buenacopa? Escríbenos y te respondemos lo antes posible."
    },
    {
      "type": "header",
      "content": "Form Labels"
    },
    {
      "type": "text",
      "id": "label_name",
      "label": "Name Label",
      "default": "Nombre"
    },
    {
      "type": "text",
      "id": "placeholder_name",
      "label": "Name Placeholder",
      "default": "Tu nombre completo"
    },
    {
      "type": "text",
      "id": "label_email",
      "label": "Email Label",
      "default": "Correo electrónico"
    },
    {
      "type": "text",
      "id": "placeholder_email",
      "label": "Email Placeholder",
      "default": "tu@correo.com"
    },
    {
      "type": "text",
      "id": "label_phone",
      "label": "Phone Label",
      "default": "Teléfono"
    },
    {
      "type": "text",
      "id": "placeholder_phone",
      "label": "Phone Placeholder",
      "default": "+52 55 1234 5678"
    },
    {
      "type": "text",
      "id": "label_message",
      "label": "Message Label",
      "default": "Mensaje"
    },
    {
      "type": "text",
      "id": "placeholder_message",
      "label": "Message Placeholder",
      "default": "¿En qué podemos ayudarte?"
    },
    {
      "type": "text",
      "id": "submit_text",
      "label": "Submit Button Text",
      "default": "Enviar mensaje"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success Message",
      "default": "¡Mensaje enviado! Te responderemos pronto."
    },
    {
      "type": "header",
      "content": "WhatsApp"
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp Link",
      "info": "e.g. https://wa.me/521234567890 or your my-coco.ai widget URL"
    },
    {
      "type": "text",
      "id": "whatsapp_label",
      "label": "WhatsApp Label",
      "default": "¿Prefieres escribirnos directo?"
    },
    {
      "type": "text",
      "id": "whatsapp_text",
      "label": "WhatsApp Button Text",
      "default": "Escríbenos por WhatsApp"
    },
    {
      "type": "header",
      "content": "Social"
    },
    {
      "type": "text",
      "id": "social_label",
      "label": "Social Section Label",
      "default": "Síguenos en redes"
    }
  ],
  "presets": [
    {
      "name": "Contact Page"
    }
  ]
}
{% endschema %}
