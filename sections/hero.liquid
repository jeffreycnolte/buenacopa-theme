<section class="overflow-hidden" style="background-color: #FDFDFC;">
  <div class="container-custom">
    {%- comment -%}Desktop: 2-column layout (text left, image right){%- endcomment -%}
    <div class="grid lg:grid-cols-2 items-center">

      <!-- Text Column -->
      <div class="pt-8 lg:py-16 lg:pr-12">
        <div class="space-y-2 lg:space-y-6 text-center lg:text-left">
          <h1 class="text-4xl sm:text-6xl md:text-7xl font-display font-black leading-[0.95]">
            <span class="text-background whitespace-nowrap">{{ section.settings.heading_line_1 | default: 'La fiesta sigue.' }}</span>
            <br>
            <span class="text-accent-contrast">{{ section.settings.heading_line_2 | default: 'La cruda no.' }}</span>
          </h1>
          <p class="text-sm md:text-xl lg:text-2xl text-background/60 max-w-lg leading-relaxed font-semibold mx-auto lg:mx-0">
            {{ section.settings.subheading | default: 'Bienestar post-fiesta. Celebra hoy. Conquista mañana.' }}
          </p>

          {%- comment -%}Desktop only: Social proof + CTAs (on mobile these live in product-showcase){%- endcomment -%}
          <div class="hidden lg:flex items-center gap-2 lg:justify-start">
            <div class="flex gap-0.5">
              {% for s in (1..5) %}
                {% render 'icon-star', size: 14, fill: '#facc15', stroke: '#facc15' %}
              {% endfor %}
            </div>
            <span class="text-background/50 text-xs font-semibold">10,000+ mañanas sin cruda</span>
          </div>

          <div class="hidden lg:block space-y-2">
            <a href="#comprar" onclick="if(window.ProductForm)ProductForm.preselectSubscription()" class="btn-cta sm:w-auto inline-flex items-center justify-center gap-2 group text-base px-8">
              {{ section.settings.cta_sub_text | default: 'Suscríbete y ahorra' }}
              <span class="group-hover:translate-x-1 transition-transform inline-flex">{% render 'icon-arrow-right', size: 20 %}</span>
            </a>
            <a href="#comprar" onclick="if(window.ProductForm)ProductForm.preselectOneTime()" class="sm:w-auto inline-flex items-center justify-center gap-2 text-sm px-8 py-2.5 rounded-xl border-2 border-background/20 text-background/60 font-bold hover:border-background/40 hover:text-background transition-all">
              {{ section.settings.cta_onetime_text | default: 'Compra única desde $349' }}
            </a>
          </div>

          <p class="hidden lg:block text-sm text-primary font-display font-bold">
            {{ section.settings.trust_text | default: 'Envío gratis y 30 días de garantía.' }}
          </p>
        </div>
      </div>

      <!-- Desktop: Product Image (hidden on mobile, shown in text column instead) -->
      <div class="hidden lg:flex items-center justify-center lg:p-16 min-h-[600px]">
        {% if section.settings.hero_image %}
          <img
            src="{{ section.settings.hero_image | image_url: width: 1152 }}"
            srcset="{{ section.settings.hero_image | image_url: width: 800 }} 800w, {{ section.settings.hero_image | image_url: width: 1152 }} 1152w"
            sizes="576px"
            alt="{{ 'sections.hero.hero_image_alt' | t }}"
            class="w-full max-w-xl object-contain"
            width="576"
            height="576"
            fetchpriority="high"
          >
        {% else %}
          <img
            src="{{ 'hero-sachet.jpg' | asset_url }}"
            alt="{{ 'sections.hero.hero_image_alt' | t }}"
            class="w-full max-w-xl object-contain"
            width="576"
            height="576"
            fetchpriority="high"
          >
        {% endif %}
      </div>
    </div>
  </div>

  <!-- Social Proof Bar (hidden on mobile/tablet — flows directly to product carousel instead) -->
  <div class="bg-accent overflow-hidden hidden lg:block">
    <!-- Mobile: scrolling marquee (hidden — social proof lives in product-showcase on mobile) -->
    <div class="sm:hidden py-3">
      <div class="flex animate-marquee whitespace-nowrap">
        {% for i in (1..2) %}
          <div class="flex shrink-0">
            <div class="flex items-center gap-2 px-5">
              <span class="text-yellow-400 shrink-0">{% render 'icon-users', size: 18 %}</span>
              <span class="text-white font-bold text-sm">10,000+</span>
              <span class="text-white font-bold text-xs">{{ 'sections.hero.social_proof_mornings' | t }}</span>
            </div>
            <div class="flex items-center gap-2 px-5">
              <div class="flex shrink-0">
                {% for s in (1..5) %}
                  {% render 'icon-star', size: 12, fill: '#facc15', stroke: '#facc15' %}
                {% endfor %}
              </div>
              <span class="text-white font-bold text-sm">4.8/5</span>
              <span class="text-white font-bold text-xs">{{ 'sections.hero.social_proof_rating' | t }}</span>
            </div>
            <div class="flex items-center gap-2 px-5">
              <span class="text-yellow-400 shrink-0">{% render 'icon-leaf', size: 18 %}</span>
              <span class="text-white font-bold text-sm">✓ {{ 'sections.hero.social_proof_ingredients' | t }}</span>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- Desktop: static grid -->
    <div class="hidden sm:block container-custom py-6">
      <div class="grid grid-cols-3 divide-x divide-white/20">
        <div class="flex items-center justify-center gap-3">
          <span class="text-yellow-400">{% render 'icon-users', size: 24 %}</span>
          <div>
            <p class="text-white font-bold text-lg">10,000+</p>
            <p class="text-white/80 font-bold text-sm">{{ 'sections.hero.social_proof_mornings' | t }}</p>
          </div>
        </div>
        <div class="flex items-center justify-center gap-3">
          <div class="flex">
            {% for s in (1..5) %}
              {% render 'icon-star', size: 16, fill: '#facc15', stroke: '#facc15' %}
            {% endfor %}
          </div>
          <div>
            <p class="text-white font-bold text-lg">4.8/5</p>
            <p class="text-white/80 font-bold text-sm">{{ 'sections.hero.social_proof_rating' | t }}</p>
          </div>
        </div>
        <div class="flex items-center justify-center gap-3">
          <span class="text-yellow-400">{% render 'icon-leaf', size: 24 %}</span>
          <div>
            <p class="text-white font-bold text-lg">✓ {{ 'sections.hero.social_proof_ingredients' | t }}</p>
            <p class="text-white/80 font-bold text-sm">{{ 'sections.hero.social_proof_safe' | t }}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading Line 1",
      "default": "La fiesta sigue."
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading Line 2",
      "default": "La cruda no."
    },
    {
      "type": "html",
      "id": "subheading",
      "label": "Subheading",
      "default": "Bienestar post-fiesta. Celebra hoy. Conquista mañana."
    },
    {
      "type": "text",
      "id": "cta_sub_text",
      "label": "Subscription CTA Text",
      "default": "Suscríbete y ahorra"
    },
    {
      "type": "text",
      "id": "cta_onetime_text",
      "label": "One-Time CTA Text",
      "default": "Compra única desde $349"
    },
    {
      "type": "html",
      "id": "trust_text",
      "label": "Trust Statement",
      "default": "Envío gratis y 30 días de garantía."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Product Image"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
