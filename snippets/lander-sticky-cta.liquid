{%- comment -%}
  Lander Sticky CTA — Mobile only
  Shows after scrolling past the hero CTA. Hides when buy box is in viewport.
  Scrolls to buy box on tap.
  Rendered from lander-hero.liquid (outside the section tag to avoid overflow clipping).
{%- endcomment -%}

{%- if sub_price > 0 -%}
  {%- assign sticky_price_whole = sub_price | divided_by: 100 -%}
  {%- assign sticky_price_cents = sub_price | modulo: 100 -%}
{%- endif -%}

<style>
  #lander-sticky-cta {
    position: fixed;
    left: 0;
    right: 0;
    bottom: -80px;
    z-index: 50;
    transition: bottom 0.3s ease;
  }
  #lander-sticky-cta.is-visible {
    bottom: 0;
  }
  @media (min-width: 1024px) {
    #lander-sticky-cta { display: none !important; }
  }
  @media (max-width: 1023px) {
    body.lander-sticky-visible iframe[title*="chat"],
    body.lander-sticky-visible iframe[src*="coco"],
    body.lander-sticky-visible div[class*="widget"][style*="fixed"],
    body.lander-sticky-visible div[style*="position: fixed"][style*="bottom"][style*="right"] {
      bottom: 64px !important;
    }
  }
</style>

<div id="lander-sticky-cta">
  <div style="background-color: #001D45; box-shadow: 0 -4px 20px rgba(0,0,0,0.25); padding: 8px 16px 12px;">
    <a
      href="#lander-buy-box"
      onclick="event.preventDefault(); (document.getElementById('lander-product-form') || document.getElementById('lander-buy-box')).scrollIntoView({behavior:'smooth', block:'start'});"
      style="display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; background-color: #00A33C; color: #fff; font-weight: 700; font-size: 15px; padding: 12px 0; border-radius: 12px; text-decoration: none;"
    >
      {% render 'icon-cart', size: 18 %}
      <span>Suscribirme{% if sticky_price_whole %} – ${{ sticky_price_whole }}{%- if sticky_price_cents and sticky_price_cents > 0 -%},{{ sticky_price_cents | prepend: '00' | slice: -2, 2 }}{%- endif -%}/mes{% endif %}</span>
    </a>
  </div>
</div>

<script>
(function() {
  function init() {
    var bar = document.getElementById('lander-sticky-cta');
    var heroCta = document.getElementById('lander-hero-cta-wrap');
    var buyBox = document.getElementById('lander-buy-box');
    if (!bar || !heroCta) return;

    var heroPast = false;
    var buyBoxInView = false;

    function update() {
      var show = heroPast && !buyBoxInView;
      if (show) {
        bar.classList.add('is-visible');
        document.body.classList.add('lander-sticky-visible');
      } else {
        bar.classList.remove('is-visible');
        document.body.classList.remove('lander-sticky-visible');
      }
    }

    // Hero CTA: when it's NOT intersecting, user has scrolled past it
    new IntersectionObserver(function(entries) {
      heroPast = !entries[0].isIntersecting;
      update();
    }, { threshold: 0 }).observe(heroCta);

    // Buy box: when ANY part is visible, hide the sticky bar
    if (buyBox) {
      new IntersectionObserver(function(entries) {
        buyBoxInView = entries[0].isIntersecting;
        update();
      }, { threshold: 0 }).observe(buyBox);
    }
  }

  if (document.readyState === 'complete') {
    init();
  } else {
    window.addEventListener('load', init);
  }
})();
</script>
