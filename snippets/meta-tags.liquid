{%- comment -%}
  Open Graph + Twitter Card + canonical.

  Image priority (highest first):
    1. page_image — Shopify-provided per-page image (product featured, article cover, etc.)
    2. shop.brand.cover_image — set in admin Settings → Brand → Cover image
    3. settings.share_image — theme-level fallback
    4. assets/og-default.jpg — last-resort bundled file

  og:type:
    - "product" on product pages (richer FB/IG card with price + availability)
    - "article" on blog/article pages
    - "website" everywhere else

  Locale:
    - Pulls request.locale.iso_code (e.g. "es-MX") and reformats to OG's
      "es_MX" shape so Facebook reads it correctly.
{%- endcomment -%}

{%- liquid
  assign og_image = page_image | default: shop.brand.cover_image | default: settings.share_image

  case request.page_type
    when 'product'
      assign og_type = 'product'
    when 'article'
      assign og_type = 'article'
    else
      assign og_type = 'website'
  endcase

  assign locale_raw = request.locale.iso_code | default: 'es-MX'
  assign locale_og = locale_raw | replace: '-', '_'
-%}

<!-- Open Graph -->
<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:title" content="{{ page_title | escape }}">
<meta property="og:locale" content="{{ locale_og }}">
{%- if page_description -%}
  <meta property="og:description" content="{{ page_description | escape }}">
{%- elsif shop.description -%}
  <meta property="og:description" content="{{ shop.description | escape }}">
{%- endif -%}
{%- if og_image -%}
  <meta property="og:image" content="https:{{ og_image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ og_image | image_url: width: 1200 }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="{{ page_title | escape }}">
{%- else -%}
  <meta property="og:image" content="{{ 'og-default.jpg' | asset_url }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="{{ shop.name | escape }}">
{%- endif -%}

{%- comment -%}
  Product-specific OG: gives FB/IG/Pinterest a richer share card with
  price + availability. Required by Meta product catalogs that ingest
  via OG (vs. the standard product feed).
{%- endcomment -%}
{%- if request.page_type == 'product' and product -%}
  {%- assign current_variant = product.selected_or_first_available_variant -%}
  <meta property="product:price:amount" content="{{ current_variant.price | money_without_currency | strip_html | strip }}">
  <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
  <meta property="product:availability" content="{% if current_variant.available %}in stock{% else %}out of stock{% endif %}">
  {%- if product.vendor != blank -%}
    <meta property="product:brand" content="{{ product.vendor | escape }}">
  {%- endif -%}
  {%- if current_variant.compare_at_price > current_variant.price -%}
    <meta property="product:original_price:amount" content="{{ current_variant.compare_at_price | money_without_currency | strip_html | strip }}">
    <meta property="product:original_price:currency" content="{{ cart.currency.iso_code }}">
  {%- endif -%}
{%- endif -%}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
{%- comment -%}
  twitter:site is optional. Only render when explicitly set via theme
  settings — guessing a handle from shop name is wrong as often as right.
{%- endcomment -%}
{%- if settings.twitter_handle != blank -%}
  <meta name="twitter:site" content="@{{ settings.twitter_handle | remove: '@' }}">
{%- endif -%}
<meta name="twitter:title" content="{{ page_title | escape }}">
{%- if page_description -%}
  <meta name="twitter:description" content="{{ page_description | escape }}">
{%- elsif shop.description -%}
  <meta name="twitter:description" content="{{ shop.description | escape }}">
{%- endif -%}
{%- if og_image -%}
  <meta name="twitter:image" content="https:{{ og_image | image_url: width: 1200 }}">
  <meta name="twitter:image:alt" content="{{ page_title | escape }}">
{%- else -%}
  <meta name="twitter:image" content="{{ 'og-default.jpg' | asset_url }}">
  <meta name="twitter:image:alt" content="{{ shop.name | escape }}">
{%- endif -%}

{%- comment -%}
  Canonical: /collections lists every collection on a one-product store and
  duplicates the homepage. Point its canonical to / so Google consolidates
  signals on the real page instead of treating it as a competing URL.
{%- endcomment -%}
{%- if request.page_type == 'list_collections' -%}
  <link rel="canonical" href="{{ shop.url }}">
{%- else -%}
  <link rel="canonical" href="{{ canonical_url }}">
{%- endif -%}
