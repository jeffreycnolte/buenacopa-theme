<!-- Open Graph -->
<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:type" content="website">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:title" content="{{ page_title | escape }}">
{% if page_description %}
  <meta property="og:description" content="{{ page_description | escape }}">
{% endif %}
{% if page_image %}
  <meta property="og:image" content="https:{{ page_image | image_url }}">
{% endif %}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ page_title | escape }}">
{% if page_description %}
  <meta name="twitter:description" content="{{ page_description | escape }}">
{% endif %}
{% if page_image %}
  <meta name="twitter:image" content="https:{{ page_image | image_url }}">
{% endif %}

{%- comment -%}
  Canonical: /collections lists every collection on a one-product store and
  duplicates the homepage. Point its canonical to / so Google consolidates
  signals on the real page instead of treating it as a competing URL.
{%- endcomment -%}
{%- if request.page_type == 'list_collections' -%}
  <link rel="canonical" href="{{ shop.url }}">
{%- else -%}
  <link rel="canonical" href="{{ canonical_url }}">
{%- endif -%}
