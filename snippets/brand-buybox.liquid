{%- comment -%}
  Brand buy-box — radio-style two-option layout (cheers-pattern).

  Single-SKU model: one product, two ways to buy.
    Tile 1 (top, anchor):     Compra única — full retail.
    Tile 2 (bottom, default): Suscripción mensual — 20% off.
  Single "Agregar al carrito" CTA below; selection is read off the
  active .bc-buybox-tile via ProductForm.selectOption.

  Caller pre-computes scalars; this snippet renders.

  Usage:
    {% render 'brand-buybox',
       id_prefix: 'lander',
       product_id: product.id,

       has_subscription: has_subscription,
       sub_variant_id: sub_variant.id,
       sub_plan_id: sub_plan.id,
       sub_price_raw: sub_price,
       sub_price_whole: sub_price_whole,
       sub_price_cents: sub_price_cents,
       sub_compare_whole: sub_compare_whole,
       sub_per_whole: sub_per_whole,
       sub_savings_whole: sub_savings_whole,

       onetime_variant_id: ot_variant.id,
       onetime_price_raw: ot_variant.price,
       onetime_price_whole: ot_price_whole,
       onetime_per_whole: ot_per_whole,
       onetime_available: ot_variant.available
    %}

  JS contract: ProductForm.selectOption(tile), .addToCart.
{%- endcomment -%}

{%- assign _shipping_text   = shipping_text   | default: 'Envíos a todo México' -%}
{%- assign _onetime_heading = onetime_heading | default: 'Compra única' -%}
{%- assign _sub_heading     = sub_heading     | default: 'Suscripción mensual' -%}
{%- assign _add_to_cart     = add_to_cart_text | default: 'Agregar al carrito' -%}
{%- assign _trust_ssl       = trust_ssl       | default: 'Pago seguro SSL' -%}
{%- assign _trust_shipping  = trust_shipping  | default: 'Envío gratis' -%}
{%- assign _trust_guarantee = trust_guarantee | default: 'Garantía 30 días' -%}

{%- if id_prefix != blank -%}
  {%- capture _id_form  -%}{{ id_prefix }}-product-form{%- endcapture -%}
  {%- capture _id_trust -%}{{ id_prefix }}-trust-badges{%- endcapture -%}
{%- else -%}
  {%- assign _id_form  = 'product-form' -%}
  {%- assign _id_trust = 'trust-badges' -%}
{%- endif -%}

{%- assign _ot_whole = onetime_price_whole | default: 0 -%}
{%- capture _ot_formatted -%}{%- if _ot_whole >= 1000 -%}{{ _ot_whole | divided_by: 1000 }},{{ _ot_whole | modulo: 1000 | prepend: '000' | slice: -3, 3 }}{%- else -%}{{ _ot_whole }}{%- endif -%}{%- endcapture -%}
{%- assign _sub_whole = sub_price_whole | default: 0 -%}
{%- capture _sub_formatted -%}{%- if _sub_whole >= 1000 -%}{{ _sub_whole | divided_by: 1000 }},{{ _sub_whole | modulo: 1000 | prepend: '000' | slice: -3, 3 }}{%- else -%}{{ _sub_whole }}{%- endif -%}{%- endcapture -%}

<div class="space-y-3 mx-auto" style="max-width: 520px;" id="{{ _id_form }}" data-product-id="{{ product_id }}">

  <style>
    .bc-radio { width:18px; height:18px; border-radius:50%; border:2px solid rgba(7,29,64,0.25); position:relative; flex-shrink:0; margin-top:1px; transition:border-color 0.15s; }
    .bc-buybox-tile.selected .bc-radio { border-color: #00A33C; }
    .bc-buybox-tile.selected .bc-radio::after { content:''; position:absolute; inset:3px; border-radius:50%; background:#00A33C; }
    .bc-buybox-tile { background:#fff; }
    .bc-buybox-tile.selected { background:linear-gradient(180deg, rgba(0,171,67,0.06) 0%, rgba(0,171,67,0.02) 100%); }
    .bc-savings-pill { display:inline-flex; align-items:center; gap:4px; background:#00A33C; color:#fff; font-weight:700; text-transform:uppercase; font-size:10px; letter-spacing:0.04em; padding:2px 8px; border-radius:999px; }
  </style>

  {%- comment -%}─── Pre-decision trust bullets (cheers-pattern) ───{%- endcomment -%}
  <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px;">
    {%- assign _bullets = 'Toma 3 cápsulas después de tu última copa o antes de dormir|Despierta como si hubieras bebido la mitad — o te devolvemos tu dinero|Ataca la cruda desde la raíz mientras apoya tu hígado' | split: '|' -%}
    {%- for b in _bullets -%}
      <li style="display:flex; align-items:flex-start; gap:10px; color:#001D45; font-size:14px; line-height:1.4;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#001D45" stroke-width="3" aria-hidden="true" style="flex-shrink:0; margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg>
        <span>{{ b }}</span>
      </li>
    {%- endfor -%}
  </ul>

  {%- comment -%}─── Shipping badge ───{%- endcomment -%}
  <div class="flex items-center gap-2 text-background/50" style="margin-top:4px;">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
    <span style="font-size:12px" class="font-medium">{{ _shipping_text }}</span>
  </div>

  {%- comment -%}─── Tile 1: Subscription (default, recommended) ───{%- endcomment -%}
  {%- if has_subscription and sub_variant_id != blank -%}
    <button
      type="button"
      class="bc-buybox-tile w-full text-left rounded-xl border-2 border-accent transition-all cursor-pointer selected"
      style="padding:14px 16px;"
      data-variant-id="{{ sub_variant_id }}"
      data-selling-plan-id="{{ sub_plan_id }}"
      data-price="{{ sub_price_raw }}"
      data-cta-prefix="Suscribirme"
      data-cta-suffix="/mes"
      data-default="true"
      onclick="ProductForm.selectOption(this)"
    >
      <div style="display:flex; align-items:flex-start; gap:12px;">
        <span class="bc-radio" aria-hidden="true"></span>
        <div style="flex:1; min-width:0;">
          <div class="flex items-baseline justify-between" style="gap:12px;">
            <div>
              <p class="font-bold text-background" style="font-size:14px; display:inline; margin-right:8px">{{ _sub_heading }}</p>
              <span class="bc-savings-pill">AHORRA 20%</span>
            </div>
            <div style="text-align:right; white-space:nowrap;">
              {%- if sub_compare_whole != blank and sub_compare_whole > _sub_whole -%}
                <span style="font-size:12px; color:rgba(7,29,64,0.4); text-decoration:line-through; font-weight:600; margin-right:4px;">${{ sub_compare_whole }}</span>
              {%- endif -%}
              <span class="font-display font-black text-background" style="font-size:20px">${{ _sub_formatted }}</span><span style="font-size:11px; color:rgba(7,29,64,0.5); font-weight:600; margin-left:2px">/mes</span>
            </div>
          </div>

          <ul style="margin-top:8px; display:flex; flex-direction:column; gap:3px; list-style:none; padding:0;">
            <li style="display:flex; align-items:center; gap:6px; font-size:11px; color:rgba(7,29,64,0.7); font-weight:500">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" aria-hidden="true" style="flex-shrink:0"><polyline points="20 6 9 17 4 12"/></svg>
              {%- if sub_savings_whole != blank and sub_savings_whole > 0 -%}
                Ahorras ${{ sub_savings_whole }} cada mes
              {%- else -%}
                20% de descuento de por vida
              {%- endif -%}
            </li>
            <li style="display:flex; align-items:center; gap:6px; font-size:11px; color:rgba(7,29,64,0.7); font-weight:500">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" aria-hidden="true" style="flex-shrink:0"><polyline points="20 6 9 17 4 12"/></svg>
              Llega cada mes — modifica, salta o cancela en cualquier momento
            </li>
          </ul>
        </div>
      </div>
    </button>
  {%- endif -%}

  {%- comment -%}─── Tile 2: One-Time ───{%- endcomment -%}
  {%- if onetime_variant_id != blank -%}
    <button
      type="button"
      class="bc-buybox-tile w-full text-left rounded-xl border-2 border-background/15 transition-all cursor-pointer {% unless onetime_available %}opacity-50 cursor-not-allowed{% endunless %}"
      style="padding:14px 16px;"
      data-variant-id="{{ onetime_variant_id }}"
      data-price="{{ onetime_price_raw }}"
      data-variant-price="{{ onetime_price_raw }}"
      data-variant-available="{{ onetime_available }}"
      data-cta-prefix="Agregar al carrito"
      onclick="ProductForm.selectOption(this)"
      {% unless onetime_available %}disabled{% endunless %}
    >
      <div style="display:flex; align-items:flex-start; gap:12px;">
        <span class="bc-radio" aria-hidden="true"></span>
        <div style="flex:1; min-width:0;">
          <div class="flex items-baseline justify-between" style="gap:12px;">
            <p class="font-bold text-background" style="font-size:14px">{{ _onetime_heading }}</p>
            <div style="text-align:right; white-space:nowrap;">
              <span class="font-display font-black text-background" style="font-size:20px">${{ _ot_formatted }}</span>
            </div>
          </div>
          <p style="font-size:11px; font-weight:500; margin-top:2px; color:rgba(7,29,64,0.55);">
            Una sola entrega · Sin recurrencia
            {%- if onetime_per_whole != blank and onetime_per_whole > 0 %} · ${{ onetime_per_whole }} por mañana sin cruda{% endif -%}
          </p>
        </div>
      </div>
    </button>
  {%- endif -%}

  {%- comment -%}─── Single CTA (inline so JS can update only the label span without wiping the cart icon) ───{%- endcomment -%}
  <div style="margin-top:8px;">
    <button
      type="button"
      id="add-to-cart-btn"
      onclick="ProductForm.addToCart()"
      class="btn-cta w-full justify-center disabled:opacity-50"
    >
      {% render 'icon-cart', size: 18 %}
      <span id="add-to-cart-label">{{ _add_to_cart }}</span>
    </button>
  </div>

  {%- comment -%}─── Trust badges ───{%- endcomment -%}
  <div class="flex items-center justify-center text-background/50" id="{{ _id_trust }}" style="gap:12px; padding:8px 0; font-size:10px">
    <style>@media(min-width:1024px) { #{{ _id_trust }} { font-size: 12px !important; } #{{ _id_trust }} svg { width: 14px; height: 14px; } }</style>
    <div class="flex items-center whitespace-nowrap" style="gap:5px; font-weight:500">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="shrink-0"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      {{ _trust_ssl }}
    </div>
    <span class="text-background/20">|</span>
    <div class="flex items-center whitespace-nowrap" style="gap:5px; font-weight:500">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="shrink-0"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
      {{ _trust_shipping }}
    </div>
    <span class="text-background/20">|</span>
    <div class="flex items-center whitespace-nowrap" style="gap:5px; font-weight:500">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="shrink-0"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      {{ _trust_guarantee }}
    </div>
  </div>

</div>
