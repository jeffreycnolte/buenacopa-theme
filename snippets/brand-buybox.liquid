{%- comment -%}
  Brand buy-box — pure view component for the canonical purchase module.

  Single-SKU model: one one-time variant + one optional subscription plan.
  Caller pre-computes all numbers; this snippet renders.

  Usage:
    {% render 'brand-buybox',
       id_prefix: 'lander',
       product_id: product.id,

       has_subscription: has_subscription,
       sub_variant_id: sub_variant.id,
       sub_plan_id: sub_plan.id,
       sub_price_raw: sub_price,
       sub_servings: sub_servings,
       sub_price_whole: sub_price_whole,
       sub_price_cents: sub_price_cents,
       sub_compare_whole: sub_compare_whole,
       sub_per_whole: sub_per_whole,

       onetime_variant_id: ot_variant.id,
       onetime_variant_title: ot_variant.title,
       onetime_price_raw: ot_variant.price,
       onetime_price_whole: ot_price_whole,
       onetime_per_whole: ot_per_whole,
       onetime_available: ot_variant.available
    %}

  Subscription card is rendered only when `has_subscription` is true and
  `sub_variant_id` is present. One-time tile is always rendered when
  `onetime_variant_id` is present.

  DOM ids the snippet emits (using id_prefix):
    {prefix-}product-form, {prefix-}subscription-card, {prefix-}variant-selector,
    {prefix-}onetime-cta, {prefix-}product-quantity, {prefix-}trust-badges
    (no leading dash if prefix is blank)

  JS contract: ProductForm.selectSubscription, .selectOneTime, .addToCart,
  .decrementQty, .incrementQty.
{%- endcomment -%}

{%- comment -%}─── Resolve defaults ───{%- endcomment -%}
{%- assign _shipping_text   = shipping_text   | default: 'Envíos a todo México' -%}
{%- assign _onetime_heading = onetime_heading | default: 'Compra única' -%}
{%- assign _sub_cta_text    = sub_cta_text    | default: 'Suscribirme ahora' -%}
{%- assign _add_to_cart     = add_to_cart_text | default: 'Agregar al carrito' -%}
{%- assign _trust_ssl       = trust_ssl       | default: 'Pago seguro SSL' -%}
{%- assign _trust_shipping  = trust_shipping  | default: 'Envío gratis' -%}
{%- assign _trust_guarantee = trust_guarantee | default: 'Garantía 30 días' -%}
{%- assign _ben_1 = sub_benefit_1 | default: '20% de descuento de por vida' -%}
{%- capture _ben_2_default -%}{%- if sub_savings_whole != blank and sub_savings_whole > 0 -%}Ahorras ${{ sub_savings_whole }} cada mes{%- else -%}20% más barato{%- endif -%}{%- endcapture -%}
{%- assign _ben_2 = sub_benefit_2 | default: _ben_2_default -%}
{%- assign _ben_3 = sub_benefit_3 | default: 'Llega cada mes' -%}
{%- assign _ben_4 = sub_benefit_4 | default: 'Pausa o cancela cuando quieras' -%}

{%- comment -%}─── DOM id helpers ───{%- endcomment -%}
{%- if id_prefix != blank -%}
  {%- capture _id_form -%}{{ id_prefix }}-product-form{%- endcapture -%}
  {%- capture _id_sub -%}{{ id_prefix }}-subscription-card{%- endcapture -%}
  {%- capture _id_variant_sel -%}{{ id_prefix }}-variant-selector{%- endcapture -%}
  {%- capture _id_onetime -%}{{ id_prefix }}-onetime-cta{%- endcapture -%}
  {%- capture _id_qty -%}{{ id_prefix }}-product-quantity{%- endcapture -%}
  {%- capture _id_trust -%}{{ id_prefix }}-trust-badges{%- endcapture -%}
{%- else -%}
  {%- assign _id_form = 'product-form' -%}
  {%- assign _id_sub = 'subscription-card' -%}
  {%- assign _id_variant_sel = 'variant-selector' -%}
  {%- assign _id_onetime = 'onetime-cta-row' -%}
  {%- assign _id_qty = 'product-quantity' -%}
  {%- assign _id_trust = 'trust-badges' -%}
{%- endif -%}

<div class="space-y-3 mx-auto" style="max-width: 520px;" id="{{ _id_form }}" data-product-id="{{ product_id }}">

  {%- comment -%}─── Shipping badge ───{%- endcomment -%}
  <div class="flex items-center gap-2 text-background/50">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
    <span style="font-size:12px" class="font-medium">{{ _shipping_text }}</span>
  </div>

  {%- comment -%}─── Subscription card ───{%- endcomment -%}
  {%- if has_subscription and sub_variant_id != blank -%}
    <div
      id="{{ _id_sub }}"
      class="relative rounded-xl border-2 border-accent cursor-pointer transition-all"
      style="background: linear-gradient(180deg, rgba(0,171,67,0.06) 0%, rgba(0,171,67,0.02) 100%); padding: 24px 16px 14px;"
      onclick="ProductForm.selectSubscription({{ sub_variant_id }}, {{ sub_plan_id }})"
      data-variant-id="{{ sub_variant_id }}"
      data-selling-plan-id="{{ sub_plan_id }}"
      data-price="{{ sub_price_raw }}"
    >
      {% render 'brand-badge', variant: 'best-value', text: 'MEJOR VALOR', class_extra: 'absolute left-3', style_extra: 'top:-11px;' %}

      <div class="flex items-start justify-between">
        <p class="font-bold text-background" style="font-size:14px">Suscripción mensual</p>
        <div style="text-align:right; white-space:nowrap;">
          {%- if sub_compare_whole != blank and sub_compare_whole > sub_price_whole -%}
            <span style="font-size:13px; color:rgba(7,29,64,0.4); text-decoration:line-through; font-weight:600; margin-right:4px;">${{ sub_compare_whole }}</span>
          {%- endif -%}
          <span class="font-display font-black text-background" style="font-size:22px">${{ sub_price_whole }}</span>{%- if sub_price_cents != blank and sub_price_cents > 0 -%}<span class="font-display font-black text-background" style="font-size:14px">.{{ sub_price_cents }}</span>{%- endif -%}<span style="font-size:11px; color:rgba(7,29,64,0.4); font-weight:600; margin-left:2px">/mes</span>
          {%- if sub_per_whole != blank and sub_per_whole > 0 -%}
            <div class="text-background/40" style="font-size:10px; text-align:right; margin-top:2px">${{ sub_per_whole }}/toma</div>
          {%- endif -%}
        </div>
      </div>

      <div class="grid grid-cols-2" style="margin-top:8px; gap:3px 12px">
        <div style="display:flex; align-items:center; gap:6px">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" aria-hidden="true" class="shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
          <span style="font-size:11px; color:rgba(7,29,64,0.65)"><strong>{{ _ben_1 }}</strong></span>
        </div>
        <div style="display:flex; align-items:center; gap:6px">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" aria-hidden="true" class="shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
          <span style="font-size:11px; color:rgba(7,29,64,0.65)">{{ _ben_2 }}</span>
        </div>
        <div style="display:flex; align-items:center; gap:6px">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" aria-hidden="true" class="shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
          <span style="font-size:11px; color:rgba(7,29,64,0.65)">{{ _ben_3 }}</span>
        </div>
        <div style="display:flex; align-items:center; gap:6px">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" aria-hidden="true" class="shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
          <span style="font-size:11px; color:rgba(7,29,64,0.65)">{{ _ben_4 }}</span>
        </div>
      </div>

      {%- capture _sub_onclick -%}event.stopPropagation(); ProductForm.selectSubscription({{ sub_variant_id }}, {{ sub_plan_id }}); ProductForm.addToCart();{%- endcapture -%}
      {%- assign _sub_cta_label = _sub_cta_text | append: ' →' -%}
      <div style="margin-top:14px;">
        {% render 'brand-button',
          tag: 'button',
          text: _sub_cta_label,
          onclick: _sub_onclick,
          full_width: true
        %}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%}─── One-time tile ───{%- endcomment -%}
  {%- if onetime_variant_id != blank -%}
    {%- assign _ot_whole = onetime_price_whole | default: 0 -%}
    {%- capture _ot_formatted -%}{%- if _ot_whole >= 1000 -%}{{ _ot_whole | divided_by: 1000 }},{{ _ot_whole | modulo: 1000 | prepend: '000' | slice: -3, 3 }}{%- else -%}{{ _ot_whole }}{%- endif -%}{%- endcapture -%}
    {%- assign _ot_onclick = 'ProductForm.addToCartOneTime()' -%}
    <div
      id="{{ _id_variant_sel }}"
      class="rounded-xl border-2 border-background/15 bg-background/5 transition-all"
      style="padding:14px 16px; margin-top:4px"
    >
      <div class="flex items-start justify-between">
        <div>
          <p class="font-bold text-background" style="font-size:14px">{{ _onetime_heading }}</p>
          <p class="text-background/50" style="font-size:11px; font-weight:600; margin-top:2px">Una sola entrega · Sin recurrencia</p>
        </div>
        <div style="text-align:right; white-space:nowrap;">
          {%- if onetime_compare_whole != blank and onetime_compare_whole > _ot_whole -%}
            <span style="font-size:13px; color:rgba(7,29,64,0.4); text-decoration:line-through; font-weight:600; margin-right:4px;">${{ onetime_compare_whole }}</span>
          {%- endif -%}
          <span class="font-display font-black text-background" style="font-size:22px">${{ _ot_formatted }}</span>
          {%- if onetime_per_whole != blank and onetime_per_whole > 0 -%}
            <div class="text-background/40" style="font-size:10px; text-align:right; margin-top:2px">${{ onetime_per_whole }}/toma</div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%}
        Hidden marker button so JS contracts that look up `.variant-btn` (sticky CTA,
        ProductForm.preselectOneTime) still work with a known data-variant-id/price.
      {%- endcomment -%}
      <button
        type="button"
        class="variant-btn"
        data-variant-id="{{ onetime_variant_id }}"
        data-variant-price="{{ onetime_price_raw }}"
        data-variant-available="{{ onetime_available }}"
        style="display:none"
        aria-hidden="true"
        tabindex="-1"
      ></button>

      <div id="{{ _id_onetime }}" style="margin-top:12px; display:flex; gap:10px; align-items:stretch;">
        {% render 'brand-quantity-stepper', quantity_id: _id_qty %}
        {% render 'brand-button',
          tag: 'button',
          text: _add_to_cart,
          onclick: _ot_onclick,
          class_extra: 'flex-1 disabled:opacity-50'
        %}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%}─── Trust badges (icon row) ───{%- endcomment -%}
  <div class="flex items-center justify-center text-background/50" id="{{ _id_trust }}" style="gap:12px; padding:8px 0; font-size:10px">
    <style>@media(min-width:1024px) { #{{ _id_trust }} { font-size: 12px !important; } #{{ _id_trust }} svg { width: 14px; height: 14px; } }</style>
    <div class="flex items-center whitespace-nowrap" style="gap:5px; font-weight:500">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="shrink-0"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      {{ _trust_ssl }}
    </div>
    <span class="text-background/20">|</span>
    <div class="flex items-center whitespace-nowrap" style="gap:5px; font-weight:500">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="shrink-0"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
      {{ _trust_shipping }}
    </div>
    <span class="text-background/20">|</span>
    <div class="flex items-center whitespace-nowrap" style="gap:5px; font-weight:500">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="shrink-0"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      {{ _trust_guarantee }}
    </div>
  </div>

</div>
