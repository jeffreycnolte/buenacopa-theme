<!DOCTYPE html>
<html lang="{{ request.locale.iso_code | default: 'es' }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }}{% unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}</title>

  {{ content_for_header }}

  {{ 'tailwind.min.css' | asset_url | stylesheet_tag }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body class="min-h-screen bg-background text-foreground font-sans antialiased flex items-center justify-center">
  <main class="container-custom text-center py-16">
    {{ content_for_layout }}
  </main>
</body>
</html>
