<!DOCTYPE html>
<html lang="{{ request.locale.iso_code | default: 'es' }}">
<head>
 {%- if content_for_header contains 'tapita-seo-script-tags' -%}{%- include 'tapita-seo-schema' -%}{%- endif -%} 

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {%- comment -%}Tapita SEO schema override — must run before title tag{%- endcomment -%}
  {%- if content_for_header contains 'tapita-seo-script-tags' -%}{%- render 'tapita-seo-schema' -%}{%- endif -%}

  <title>{{ page_title }}{% unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}</title>
  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {%- comment -%}Favicon{%- endcomment -%}
  {%- if settings.favicon -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  {{ content_for_header }}

  {%- comment -%}
    Preconnect — max 4 origins, only those on the critical path.
    Removed: shop.app (unused), duplicate cdn.shopify.com entries.
    Added: fonts.gstatic.com (saves ~330ms LCP), static-tracking.klaviyo.com (saves ~300ms LCP).
  {%- endcomment -%}
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="dns-prefetch" href="https://fonts.googleapis.com">
  <link rel="dns-prefetch" href="https://static-tracking.klaviyo.com">

  {%- comment -%}Preload LCP hero image (homepage only) with srcset for responsive delivery{%- endcomment -%}
  {%- if request.page_type == 'index' -%}
    <link rel="preload" as="image" href="{{ 'hero-sachet.jpg' | asset_url }}" fetchpriority="high"
      imagesrcset="{{ 'hero-sachet.jpg' | asset_url }} 576w"
      imagesizes="(max-width: 768px) 320px, 576px">
  {%- endif -%}

  {%- comment -%}Fonts — non-render-blocking via media swap{%- endcomment -%}
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Nunito:wght@400;700;800;900&display=swap">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Nunito:wght@400;700;800;900&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Nunito:wght@400;700;800;900&display=swap" rel="stylesheet"></noscript>

  {%- comment -%}
    Stylesheets — theme.css is small (~2.3 KiB) so we inline-critical + async the larger Tailwind.
    Tailwind (7 KiB) loads non-blocking via media swap to avoid render-blocking.
  {%- endcomment -%}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <link rel="preload" href="{{ 'tailwind.min.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript>{{ 'tailwind.min.css' | asset_url | stylesheet_tag }}</noscript>

  {% render 'meta-tags', page_description: page_description, page_title: page_title %}

  {%- comment -%}Organization JSON-LD{%- endcomment -%}
  {%- assign social_links = '' -%}
  {%- if settings.social_instagram_link != blank -%}{%- assign social_links = social_links | append: settings.social_instagram_link | append: '|' -%}{%- endif -%}
  {%- if settings.social_facebook_link != blank -%}{%- assign social_links = social_links | append: settings.social_facebook_link | append: '|' -%}{%- endif -%}
  {%- if settings.social_tiktok_link != blank -%}{%- assign social_links = social_links | append: settings.social_tiktok_link | append: '|' -%}{%- endif -%}
  {%- if settings.social_twitter_link != blank -%}{%- assign social_links = social_links | append: settings.social_twitter_link | append: '|' -%}{%- endif -%}
  {%- if settings.social_youtube_link != blank -%}{%- assign social_links = social_links | append: settings.social_youtube_link | append: '|' -%}{%- endif -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": {{ shop.url | json }},
    "logo": {{ settings.logo | default: 'logo-offwhite.png' | asset_url | prepend: 'https:' | json }},
    "description": {{ shop.description | json }}
    {%- if social_links != blank -%}
    ,"sameAs": [
      {%- assign links_array = social_links | split: '|' -%}
      {%- for link in links_array -%}
        {%- if link != blank -%}
          {{ link | json }}{%- unless forloop.last -%},{%- endunless -%}
        {%- endif -%}
      {%- endfor -%}
    ]
    {%- endif -%}
  }
  </script>
</head>
<body class="min-h-screen bg-background text-foreground font-sans antialiased">
  <a class="skip-to-content" href="#main-content">{{ 'general.skip_to_content' | t }}</a>

  {%- comment -%}Announcement bar{%- endcomment -%}
  {%- if settings.announcement_enable -%}
    <div class="announcement-bar" role="region" aria-label="{{ 'general.announcement' | t }}" style="background-color: {{ settings.announcement_bg_color }}; color: {{ settings.announcement_text_color }};">
      <div class="container-custom py-2 text-center text-sm font-medium">
        {%- if settings.announcement_link != blank -%}
          <a href="{{ settings.announcement_link }}" class="announcement-bar__link" style="color: {{ settings.announcement_text_color }};">
            {{ settings.announcement_text }}
          </a>
        {%- else -%}
          {{ settings.announcement_text }}
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {% section 'header' %}

  <main id="main-content" class="pb-16 lg:pb-0">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {% render 'cart-drawer' %}

  {%- comment -%}Translation strings for JavaScript{%- endcomment -%}
  <script>
    window.theme = window.theme || {};
    window.theme.strings = {
      addToCart: {{ 'general.cart.add_to_cart' | t | json }},
      cartLoad: {{ 'general.errors.cart_load' | t | json }},
      cartAdd: {{ 'general.errors.cart_add' | t | json }},
      cartUpdate: {{ 'general.errors.cart_update' | t | json }},
      cartRemove: {{ 'general.errors.cart_remove' | t | json }},
      processError: {{ 'general.errors.process_error' | t | json }},
      removeAria: {{ 'general.cart.remove' | t | json }},
      decreaseQty: {{ 'general.cart.decrease_qty' | t | json }},
      increaseQty: {{ 'general.cart.increase_qty' | t | json }},
      quantityAria: {{ 'general.cart.quantity' | t | json }}
    };
  </script>

  {%- comment -%}
    Core theme JS — these are small and needed for interactivity.
    Keep defer (not delayed) so cart/product forms work immediately.
  {%- endcomment -%}
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
  <script src="{{ 'cart-drawer.js' | asset_url }}" defer></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer></script>
  <script src="{{ 'video-section.js' | asset_url }}" defer></script>

  {%- comment -%}
    Delayed third-party loader — defers analytics/tracking/widgets
    until first user interaction or 5s timeout. All functionality
    preserved, just moved off the critical path.
  {%- endcomment -%}
  {% render 'delay-third-party' %}

  {%- comment -%}
    TikTok Pixel — managed by Shopify TikTok sales channel.
    Pixel ID: D1JEHJRC77U87UH7IK6G
    Data sharing: Maximum (Pixel + Events API + Advanced Matching)
    Configured: 2026-03-25
    Verify: performance.getEntriesByType('resource').filter(e => e.name.includes('tiktok'))
  {%- endcomment -%}
</body>
</html>
